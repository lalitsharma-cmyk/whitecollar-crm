  CALL_SWITCHED_OFF
  CALL_WRONG_NUMBER
  CALL_LATER
  WHATSAPP_SENT
  WHATSAPP_RECEIVED
  EMAIL_LOGGED
  INTERVIEW_SCHEDULED
  INTERVIEW_ATTENDED
  INTERVIEW_NO_SHOW
  INTERVIEW_RESCHEDULED
  OFFER_RELEASED
  OFFER_DECLINED
  CANDIDATE_JOINED
  FOLLOWUP_CREATED
  FOLLOWUP_COMPLETED
  STATUS_CHANGED
  NOTE_ADDED
}

enum HRInterviewType {
  VIRTUAL
  HR
  FINAL
  FACE_TO_FACE
}

enum HRConfirmStatus {
  PENDING
  CONFIRMED
  NOT_CONFIRMED
  NOT_REACHABLE
  RESCHEDULED
  CANCELLED
}

enum HRAttendStatus {
  SCHEDULED
  ATTENDED
  NO_SHOW
  RESCHEDULED
  CANCELLED
}

enum HRFollowUpType {
  CALL_BACK
  INTERVIEW_CONFIRMATION
  REMINDER
  WHATSAPP_FOLLOWUP
  EMAIL_FOLLOWUP
  SALARY_DISCUSSION
  OFFER_DISCUSSION
  JOINING_FOLLOWUP
  NO_SHOW_RECOVERY
  CUSTOM
}

model HRCandidate {
  id               String            @id @default(cuid())
  name             String
  phone            String?
  altPhone         String?
  whatsappPhone    String?
  email            String?
  location         String?           // current location
  city             String?           // home city
  currentCompany   String?
  currentProfile   String?           // current designation / job title
  positionApplied  String?           // role being recruited for (Sales Executive, BDE, BDM, …)
  experience       String?           // total experience — "2 years", "5+ years"
  realEstateExperience String?       // real-estate-specific experience
  currentSalary    Float?
  expectedSalary   Float?
  noticePeriod     String?           // "Immediate", "30 days", "60 days", "90 days"
  source           String?           // "LinkedIn", "Naukri", "Referral", "Walk-in", etc.
  status           HRCandidateStatus @default(NEW)
  // Exact status text from the Excel import (e.g. "Rejected in HR Interview").
  // Preserved verbatim and shown as the display status; `status` above is the
  // mapped CRM category used for dashboards/filters. Excel is the source of truth.
  originalStatus   String?
  remarks          String?           // "Display Remark" (currently == rawRemarks)
  rawRemarks       String?           // IMMUTABLE audit source of truth: exact imported remark text, never transformed/overwritten. Shown verbatim in Raw History (Audit Log).
  tags             String?           // comma-separated
  nextAction       String?
  nextActionDate   DateTime?
  joiningDate      DateTime?   // expected / confirmed joining date
  // HR assessment (Candidate Fit) — "Good" / "Average" / "Weak" / null = Not Checked
  fitExperience      String?
  fitCommunication   String?
  fitStability       String?
  fitSalary          String?
  fitNotice          String?
  interviewFeedback  String?  @db.Text
  joiningProbability String?   // High / Medium / Low
  primaryOwnerId   String?
  secondaryOwnerId String?
  // phone||email dedup fingerprint (same logic as Lead)
  fingerprint      String?           @unique
  // The bulk import batch that created this candidate — drives Import History
  // "Delete this batch" (removes the candidate + cascaded workflow records).
  importBatchId    String?
  importBatch      HRImport?         @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  primaryOwner     User?             @relation("HRPrimary",   fields: [primaryOwnerId],   references: [id])
  secondaryOwner   User?             @relation("HRSecondary", fields: [secondaryOwnerId], references: [id])
  activities       HRActivity[]
  interviews       HRInterview[]
  followUps        HRFollowUp[]
  resumes          HRResume[]
  applications     HRApplication[]   // every website/form submission (re-applies append here)

  @@index([status])
  @@index([primaryOwnerId])
  @@index([nextActionDate])
  @@index([createdAt])
  @@index([importBatchId])
}

model HRActivity {
  id          String             @id @default(cuid())
  candidateId String
  candidate   HRCandidate        @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?              @relation("HRActivities", fields: [userId], references: [id])
  type        HRActivityType
  notes       String?            @db.Text
  oldStatus   HRCandidateStatus?
  newStatus   HRCandidateStatus?
  createdAt   DateTime           @default(now())

  @@index([candidateId, createdAt])
}

model HRInterview {
  id                 String          @id @default(cuid())
  candidateId        String
  candidate          HRCandidate     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  type               HRInterviewType
  scheduledAt        DateTime
  interviewerId      String?
  interviewer        User?           @relation("HRInterviewer", fields: [interviewerId], references: [id])
  confirmationStatus HRConfirmStatus @default(PENDING)
  attendanceStatus   HRAttendStatus  @default(SCHEDULED)
  result             String?
  notes              String?         @db.Text
  noShowReason       String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([candidateId])
  @@index([scheduledAt])
}

model HRFollowUp {
  id          String         @id @default(cuid())
  candidateId String
  candidate   HRCandidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?          @relation("HRFollowUps", fields: [userId], references: [id])
  type        HRFollowUpType @default(CALL_BACK)
  dueAt       DateTime
  completedAt DateTime?
  notes       String?
  autoCreated Boolean        @default(false)
  createdAt   DateTime       @default(now())

  @@index([candidateId])
  @@index([dueAt])
  @@index([completedAt])
}

model HRImport {
  id           String   @id @default(cuid())
  fileName     String
  importedById String?
  importedBy   User?    @relation("HRImports", fields: [importedById], references: [id])
  total        Int      @default(0)
  imported     Int      @default(0)
  updated      Int      @default(0)
  failed       Int      @default(0)
  skipped      Int      @default(0)
  errors       String?  @db.Text   // JSON array of {row, reason} for the error report
  createdAt    DateTime @default(now())

  candidates   HRCandidate[]

  @@index([createdAt])
}

model HRResume {
  id           String      @id @default(cuid())
  candidateId  String
  candidate    HRCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  url          String      // Vercel Blob URL or base64 dataURL
  filename     String
  mimeType     String      @default("application/pdf")
  sizeBytes    Int?
  isActive     Boolean     @default(true)
  uploadedById String?
  uploadedBy   User?       @relation("HRResumeUploads", fields: [uploadedById], references: [id])
  createdAt    DateTime    @default(now())

  @@index([candidateId])
}

// One row per website/form submission. A re-applying candidate (matched by
// mobile/email) does NOT create a duplicate HRCandidate — a new HRApplication is
// appended instead, so the profile shows the full application history + statuses.
model HRApplication {
  id                 String            @id @default(cuid())
  candidateId        String
  candidate          HRCandidate       @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  positionApplied    String
  source             String            // Website Career Page | Website Job Application | Walk-in Form | Internship Form | HR Landing Page
  locationPreference String?
  experience         String?
  resumeId           String?           // → the HRResume created for this submission (if any)
  statusAtApply      HRCandidateStatus @default(NEW)
  submittedAt        DateTime          // form submission timestamp (from payload, else now)
  rawPayload         Json?             // original submission, for audit / replay
  createdAt          DateTime          @default(now())

  @@index([candidateId, submittedAt])
  @@index([source])
}

// Delivery + failed-submission log for the real-time website→HR intake. Every
// POST /api/intake/hr writes exactly one row (success OR failure).
model HRIntakeLog {
  id            String   @id @default(cuid())
  receivedAt    DateTime @default(now())
  source        String?
  outcome       String   // CREATED | APPENDED | FAILED
  httpStatus    Int
  candidateId   String?
  applicationId String?
  error         String?  @db.Text
  payload       Json?
  ip            String?

  @@index([receivedAt])
  @@index([outcome])
}

// =====================================================
// BUYER DATA MODULE — TRANSACTION & PROPERTY RECORDS
// =====================================================

// Buyer record — transaction-level data for properties sold/under agreement.
// ADMIN-only gate: contains passport & financial data.
// buyerKey = normalized (name/phone) for repeat-buyer rollup detection.
model BuyerRecord {
  id                String   @id @default(cuid())
  // Client info
  clientName        String   // Primary buyer name
  coBuyerNames      String?  // JSON: ["Name 1", "Name 2"] — co-buyers / family members
  phones            String?  // JSON: ["+9711234567", "..."] — all contact phones
  emails            String?  // JSON: ["email@example.com"] — email addresses
  passport          String?  // Passport number (sensitive data — ADMIN only)
  nationality       String?  // e.g. "Indian", "UAE National"
  passportExpiry    String?  // Passport expiry (free text — sheets store dd/mm/yyyy etc.; kept verbatim)
  ownerName         String?  // Registered owner name (may differ from the buyer/client)
  country           String?  // Property / buyer country (e.g. "UAE", "India")
  // Property details
  projectName       String?  // e.g. "Burj Vista", "Godrej Properties Mumbai"
  tower             String?  // Tower / Building name
  unitNumber        String?  // Unit/Apartment/Villa number
  propertyType      String?  // "Residential", "Commercial", "Plot"
  configuration     String?  // e.g. "2BR", "3BR+M", "Shop"
  size              String?  // Size as written on the sheet (e.g. "1,250 sq.ft", "120 sqm")
  actualSize        String?  // Actual / carpet size (verbatim) when the sheet distinguishes it
  area              String?  // Locality / community / area (e.g. "Downtown", "Sector 150")
  // Transaction details
  transactionValue  Float?   // Deal price in market currency
  pricePerSqFt      Float?   // Price / sqft (useful for comparables)
  transactionDate   DateTime? // Date of transaction / agreement
  transactionId     String?  // Deal ID / Transaction reference number
  transactionType   String?  // "Primary", "Resale", "Rent", "Off-plan", etc.
  role              String?  // Buyer's role in the deal (e.g. "Buyer", "Seller", "Investor")
  // Agent & source
  agentName         String?  // Sales agent name (may differ from system User)
  source            String?  // "Sheet import", "Manual entry", "Excel batch"
  sourceFile        String?  // Original filename (if imported)
  // Flexibility — preserve unmapped columns from import sheets as JSON
  extraFields       Json?    // { "fieldName": "value", ... } for custom sheet columns
  // IMMUTABLE audit of the ENTIRE original import row (every column, incl. mapped
  // ones). Mirrors Lead.rawImport — guarantees every imported value is recoverable
  // verbatim. Surfaced in the buyer detail Imported Fields ("Original Imported Row").
  // NOTE: BuyerRecord.remarks (below, lifecycle section) doubles as the verbatim
  // imported-remarks store (= Raw History source, like Lead.rawRemarks) AND the
  // working notes — the buyer detail Raw History + Smart Timeline both read it.
  rawImport         Json?    // verbatim full import row { "<header>": "<value>", ... }
  // Repeat-buyer detection
  buyerKey          String?  // Normalized (fname+lname+phone hash) for rollup. Index for dedup.
  // ── Market segregation (Dubai Buyer Data) ───────────────────────────────────
  // THIS module is "Dubai Buyer Data" — only Dubai/UAE buyers live here. The
  // `market` field is the seam that keeps it market-scoped: every read in this
  // module pins market:"Dubai" (see DUBAI_MARKET / dubaiBuyerWhere in
  // src/lib/buyerScope.ts), assignment is limited to Dubai-team users + admins,
  // and visibility is Dubai-team + admin only. A FUTURE Gurgaon/India Buyer Data
  // module will be a SEPARATE module with its own market value (e.g. "Gurgaon"),
  // its own pages, and its own assignment rules — do NOT turn this into a shared
  // all-markets system by widening these queries.
  market            String   @default("Dubai") // "Dubai" today; future modules use their own value.
  // Metadata
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  importBatchId     String?  // Link to BuyerImportBatch (when bulk-imported)

  // ── Lifecycle / worked-pipeline (Part 5a) ──────────────────────────────────
  // BuyerRecord is no longer a flat admin repository — it is a lightweight Leads-
  // style pipeline: Admin Pool → assigned to an agent → CONVERTED (became a real
  // Lead) or REJECTED/returned to the pool. ownerId null ⇒ sitting in the pool.
  ownerId           String?  // agent currently working this buyer (null = Admin Buyer Pool)
  owner             User?    @relation("BuyerOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  assignedAt        DateTime? // when ownerId was last set
  poolStatus        String   @default("ADMIN_POOL") // ADMIN_POOL | ASSIGNED | CONVERTED | REJECTED
  attemptCount      Int      @default(0) // contact attempts (No Answer / Not Picked / WA No Response). Auto-return to pool at 5.
  remarks           String?  // free-text working notes — RETAINED across reassignments
  // Conversion → a real Lead.
  convertedLeadId   String?  // FK → Lead (the created lead). SetNull so deleting the lead doesn't delete the buyer.
  convertedLead     Lead?    @relation("BuyerConvertedLead", fields: [convertedLeadId], references: [id], onDelete: SetNull)
  convertedAt       DateTime?
  convertedById     String?  // user who converted
  // Rejection / return to pool.
  rejectedAt        DateTime?
  rejectedById      String?  // agent who rejected/returned
  rejectionReason   String?
  returnedToPoolAt  DateTime? // when it last went back to the Admin Pool (reject OR auto-5-attempts)
  // Recycle-bin (Part 5b) — admin bulk-delete is REVERSIBLE. A soft-deleted buyer
  // is excluded from every list/pool/rollup/dedup read (deletedAt:null filter) but
  // the row + its assignment/activity history are retained and can be restored.
  deletedAt         DateTime?
  deletedById       String?  // admin who soft-deleted it

  // Agent-handling history (who worked it, attempts, returns) + buyer-scoped activity log.
  assignments       BuyerAssignment[]
  activities        BuyerActivity[]
  stickyNotes       BuyerStickyNote[]

  @@index([buyerKey])
  @@index([projectName])
  @@index([transactionDate])
  @@index([createdAt])
  @@index([importBatchId])
  @@index([ownerId])
  @@index([poolStatus])
  @@index([ownerId, poolStatus])
  @@index([deletedAt])
  @@index([market])
}

// ── BuyerAssignment — agent-handling history ─────────────────────────────────
// One row per "stint": the period a single agent held a buyer. Opened on assign,
// closed (returnedAt set) on reject / auto-5-attempts / admin reassign. This is
// the admin-visible audit of WHO handled a buyer, HOW MANY attempts they logged
// in that stint, and WHY it came back. History is never deleted on reassignment.
model BuyerAssignment {
  id              String      @id @default(cuid())
  buyerId         String
  buyer           BuyerRecord @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  userId          String      // agent who held the buyer for this stint
  user            User        @relation("BuyerAssignmentAgent", fields: [userId], references: [id])
  assignedAt      DateTime    @default(now())
  assignedById    String?     // admin/manager who made the assignment
  returnedAt      DateTime?   // null = still the active stint
  returnReason    String?     // MANUAL_REJECT | AUTO_5_ATTEMPTS | ADMIN_REASSIGN
  attemptsInStint Int         @default(0) // contact attempts logged DURING this stint
  createdAt       DateTime    @default(now())

  @@index([buyerId])
  @@index([userId])
}

// ── BuyerActivity — buyer-scoped timeline / activity log ─────────────────────
// Calls, notes, WhatsApp, voice notes, attempts, and lifecycle transitions
// (ASSIGNED / RETURNED / CONVERTED / REJECTED). Powers the buyer's conversation
// timeline (5b) and the buyer reports (6) — calls logged, WA interactions, notes,
// voice notes, attempt counts. type is a free string (mirrors the Activity model's
// string-typed buyer side) so new kinds don't need a migration.
model BuyerActivity {
  id          String      @id @default(cuid())
  buyerId     String
  buyer       BuyerRecord @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  userId      String?     // who logged it (null for system rows)
  user        User?       @relation("BuyerActivityUser", fields: [userId], references: [id])
  // CALL | NOTE | WHATSAPP | VOICE_NOTE | ATTEMPT_NO_ANSWER | ATTEMPT_NOT_PICKED |
  // ATTEMPT_WA_NO_RESPONSE | ASSIGNED | RETURNED | CONVERTED | REJECTED
  type        String
  description String?
  createdAt   DateTime    @default(now())

  @@index([buyerId])
  @@index([userId])
  @@index([buyerId, createdAt])
}

// ── BuyerStickyNote — per-agent private scratchpad on a buyer ─────────────────
// Mirrors StickyNote (the Lead one): unique on (buyerId, userId) so every user
// gets exactly one private note per buyer. Never shown to other users. Powers the
// buyer-detail Quick Note widget at parity with the Lead view.
model BuyerStickyNote {
  id        String      @id @default(cuid())
  buyerId   String
  buyer     BuyerRecord @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation("BuyerStickyNoteUser", fields: [userId], references: [id], onDelete: Cascade)
  body      String      @default("")
  updatedAt DateTime    @updatedAt
  createdAt DateTime    @default(now())

  @@unique([buyerId, userId])
  @@index([userId])
}

// Bulk import batches — track where BuyerRecords came from (Google Sheet, Excel, etc.)
model BuyerImportBatch {
  id            String   @id @default(cuid())
  source        String   // "Google Sheet", "Excel file", etc.
  sourceRef     String?  // URL or file name
  recordCount   Int      @default(0)  // Number of rows imported
  successCount  Int      @default(0)  // Rows created/updated successfully
  errorCount    Int      @default(0)  // Rows failed (logged in BuyerImportLog)
  importedAt    DateTime @default(now())
  importedById  String?  // User who ran the import
  importedBy    User?    @relation("BuyerImports", fields: [importedById], references: [id])
  rawPayload    Json?    // Original sheet data (for audit / replay)

  @@index([importedAt])
}

// Import error log — one row per failed record during BuyerImportBatch
model BuyerImportLog {
  id        String   @id @default(cuid())
  batchId   String   // Reference to BuyerImportBatch
  rowNum    Int      // Row number in source sheet
  error     String   @db.Text  // Error message (missing required field, invalid date, etc.)
  rawRow    Json?    // Original row data
  createdAt DateTime @default(now())

  @@index([batchId])
}

// ─────────────────────────────────────────────────────────────────────────────
// GALLERY / RESOURCE LIBRARY — client-shareable content (brochures, payment
// plans, creatives, images, PDFs, text templates). Admin/Manager upload;
// agents view + share. Each resource is EXACTLY ONE of:
//   • FILE — uploaded bytes (≤5 MB image/* or application/pdf) in fileData.
//   • URL  — externally-hosted file; admin pastes a link in fileUrl (no upload).
//   • TEXT — a text template in textContent (no file).
//
// STORAGE NOTE: there is NO blob backend (@vercel/blob/S3/Cloudinary) in this
// app, so uploaded files live in Postgres bytea (fileData). The size cap keeps
// rows small; fileData is NEVER selected in list queries — only streamed by the
// public download endpoint. For large-file / high-volume use, provisioning
// Vercel Blob (BLOB_READ_WRITE_TOKEN + @vercel/blob) is the recommended future
// upgrade — an infra/billing decision, not done here.
// ─────────────────────────────────────────────────────────────────────────────
enum ResourceType {
  FILE   // uploaded bytes stored in fileData
  URL    // external link in fileUrl
  TEXT   // text template in textContent
}

enum ResourceShareChannel {
  WHATSAPP
  EMAIL
  ATTACH   // attached to in-CRM lead communication (no external send)
}

model Resource {
  id           String       @id @default(cuid())
  title        String
  // Flexible category string (Brochure | Payment Plan | Creative | Image | PDF |
  // Template | Other …). Kept a free string so admins can add categories without
  // a migration. UI offers the common set + free entry.
  category     String       @default("Other")
  type         ResourceType
  // ── FILE fields (type = FILE) ──
  fileName     String?
  mimeType     String?
  fileSize     Int?         // bytes — display + cap enforcement
  // Raw bytes. NEVER selected in list/search queries (only the download route
  // selects it). Nullable so URL/TEXT rows carry no blob.
  fileData     Bytes?
  // ── URL field (type = URL) ──
  fileUrl      String?
  // ── TEXT field (type = TEXT) ──
  textContent  String?      @db.Text
  // Optional association tags.
  projectName  String?      // associate with a project (free string)
  tags         String?      // comma-separated tags for search
  uploadedById String?
  uploadedBy   User?        @relation("ResourceUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?    // soft-delete (recycle, reversible)

  shares       ResourceShare[]

  @@index([category])
  @@index([type])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([projectName])
}

// One row per share event — "which file was shared with which client, how".
model ResourceShare {
  id          String               @id @default(cuid())
  resourceId  String
  resource    Resource             @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  // Nullable — a share may be ad-hoc (copied a link from the gallery with no lead).
  leadId      String?
  lead        Lead?                @relation("ResourceShareLead", fields: [leadId], references: [id], onDelete: SetNull)
  sharedById  String?
  sharedBy    User?                @relation("ResourceSharedBy", fields: [sharedById], references: [id], onDelete: SetNull)
  channel     ResourceShareChannel
  recipient   String?              // phone / email captured at share time
  note        String?
  sharedAt    DateTime             @default(now())

  @@index([resourceId])
  @@index([leadId])
  @@index([sharedById])
  @@index([sharedAt])
}
