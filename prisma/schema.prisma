// White Collar Realty CRM — Database schema
// Dev: SQLite (file-based, no setup). Prod: switch provider to "postgresql".

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// USERS, ROLES, TEAMS, AUTH
// =====================================================

enum Role {
  ADMIN
  MANAGER
  AGENT
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String
  passwordHash  String
  role          Role       @default(AGENT)
  team          String?    // "Dubai" / "India" / "HQ"
  phone         String?
  // Acefone agent ID — required for click-to-call (Acefone rings this number first,
  // then dials the lead once the agent picks up). Configure in /team page.
  acefoneAgentId String?
  // Company-assigned WhatsApp Business number for this agent (e.g. "+918XXXXXXX").
  // Used for: (1) outbound WA links open with this number visible to client,
  // (2) when Meta Cloud API is configured, the CRM can poll messages for this
  // number's wa_id and auto-log conversations as Activity rows.
  companyWhatsAppNumber String?
  // Profile photo — stored as base64 dataURL (kept small, no S3 needed for ~10 users).
  // Empty string ("" or null) → fall back to initials avatar.
  photoUrl              String?
  // Reporting line — Managers see leads owned by their direct reports.
  // Self-ref FK. Set in /team page (admin only).
  managerId     String?
  manager       User?      @relation("Reports", fields: [managerId], references: [id])
  reports       User[]     @relation("Reports")
  // Day-of-week the agent is off, JS getDay() convention (0=Sunday … 6=Saturday); null = no fixed weekly off.
  weeklyOff     Int?
  avatarColor   String?    // tailwind class e.g. "bg-indigo-500"
  active        Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // ── Gamification (Phase 2 of CRM master spec) ──
  // Cumulative XP earned across all actions (calls, conversions, bookings).
  // Level derived from XP via tiers in src/lib/gamification.ts. Streaks track
  // consecutive days the agent met their minimum activity threshold.
  xp                Int       @default(0)
  dailyStreak       Int       @default(0)
  followupStreak    Int       @default(0)
  coldCallStreak    Int       @default(0)
  // Last day (YYYY-MM-DD IST) the streak was incremented — used to detect
  // gaps so the streak resets after a missed day.
  lastStreakDay     String?
  // Comma-separated badge IDs earned. Defined in src/lib/gamification.ts.
  // Cheap-to-query string instead of a join table since badges are append-only.
  badges            String    @default("")

  // ── Agent profile (spec §9.13) ──
  // Comma-separated specialization tags from a fixed vocab. Examples:
  // "Dubai investor", "Gurgaon luxury", "Villa closer", "Commercial", "NRI",
  // "First-time buyer", "Negotiation support". NULL = no specialization yet.
  // Used by lead-routing hints + manager triage.
  specializations   String?
  // Per-agent daily call target. Surfaced in DailyMissionBoard so the agent
  // knows their personal goal for the day. Editable by ADMIN/MANAGER on /team.
  dailyCallTarget     Int       @default(30)
  // Per-agent daily connect target. Surfaced in DailyMissionBoard (connecting calls mission).
  dailyConnectTarget  Int       @default(10)

  // ── Per-user notification preferences ──
  // JSON-stringified object of `{ kind: boolean }` toggles plus a "sound" key
  // for in-app sound effects. Keys map to notification kinds shown in the
  // /settings → "🔕 Notification preferences" card. Example:
  //   {"hot_lead":true,"followup":true,"sla":true,"daily_report":false,"sound":true}
  // NULL = defaults (everything on). Filtering at send-time is wired up later;
  // for now this column only persists the user's choices.
  notifPrefs        String?
  // Chosen in-app alert sound id (bell|alert|chime|success|siren|premium) and
  // volume level (low|medium|high|maximum). NULL = defaults (premium / high).
  // Saved per user so the choice follows them across devices; the client also
  // caches them in localStorage so the AudioContext can fire without a round-trip.
  notifSound        String?
  notifVolume       String?

  // ── HR-only access flag ──
  // When true, this user can ONLY access the HR Recruitment module (/hr/*).
  // The Sales CRM layout redirects them to /hr immediately. Use for dedicated
  // HR staff (Nisha, HR Intern) who should never see sales leads/properties.
  hrOnly            Boolean   @default(false)
  // Admins who also work in HR — appear in HR pickers (owner/interviewer) without losing Sales access.
  hrTeam            Boolean   @default(false)
  // ── Conversation moderation (Lalit-only) ──
  // When true, this user can hide / soft-delete / restore individual remarks in
  // a lead's Conversation History, and hide them from specific or all agents.
  // NOT granted by the ADMIN role — must be set explicitly (Lalit). Normal
  // agents and even other admins never see these controls.
  canControlConversations Boolean @default(false)
  // ── Super Admin (Lalit) ──
  // The ONLY tier allowed to permanently purge data (e.g. empty Import Trash).
  // Regular admins can move imports to Trash and restore them, but can never
  // physically delete. Set explicitly — not implied by the ADMIN role.
  isSuperAdmin            Boolean @default(false)
  // ── Lead-Ops / Support-Admin flag (Sameer) ──
  // When true, this ADMIN is a lead-distribution manager, NOT a sales agent.
  // The dashboard hides every personal-performance card (he owns no leads) and
  // shows the management queue instead (unassigned / awaiting-team / workload).
  // Set explicitly per user — NOT implied by the ADMIN role (Lalit is unaffected).
  leadOpsOnly             Boolean @default(false)

  // ── Device-security (trusted-device binding) ──
  // sessionEpoch: bump to instantly revoke ALL of this user's sessions (kill switch).
  // passwordChangedAt: forces re-login everywhere after a password reset.
  // deviceLimitExtra: extra approved-device slots beyond the default (1 mobile +
  // 1 desktop); e.g. an admin grants a tablet → set to 1.
  sessionEpoch            Int       @default(0)
  passwordChangedAt       DateTime?
  deviceLimitExtra        Int       @default(0)

  ownedLeads    Lead[]     @relation("LeadOwner")
  assignments   Assignment[]
  activities    Activity[]
  callLogs      CallLog[]
  notes         Note[]
  auditLogs     AuditLog[]
  fieldChanges  LeadFieldHistory[] @relation("FieldChangedBy")
  activityEdits ActivityEdit[]     @relation("ActivityEditedBy")
  notifications Notification[]
  vaultEntries  VaultEntry[]
  stickyNotes   StickyNote[]
  devices         Device[]
  approvedDevices Device[]      @relation("DeviceApprover")
  loginSessions   UserSession[]

  // ── HR Recruitment module relations ──
  hrCandidatesPrimary   HRCandidate[] @relation("HRPrimary")
  hrCandidatesSecondary HRCandidate[] @relation("HRSecondary")
  hrActivities          HRActivity[]  @relation("HRActivities")
  hrInterviews          HRInterview[] @relation("HRInterviewer")
  hrFollowUps           HRFollowUp[]  @relation("HRFollowUps")
  hrResumeUploads       HRResume[]    @relation("HRResumeUploads")
  hrImports             HRImport[]    @relation("HRImports")

  // ── Import History (Sales) relations ──
  importBatches         ImportBatch[] @relation("ImportBatchImporter")
  deletedImportBatches  ImportBatch[] @relation("ImportBatchDeleter")

  // ── Buyer Data module relations ──
  buyerImports          BuyerImportBatch[] @relation("BuyerImports")
  buyersOwned           BuyerRecord[]      @relation("BuyerOwner")
  buyerAssignments      BuyerAssignment[]  @relation("BuyerAssignmentAgent")
  buyerActivities       BuyerActivity[]    @relation("BuyerActivityUser")
  buyerStickyNotes      BuyerStickyNote[]  @relation("BuyerStickyNoteUser")

  assistantRuns         AssistantRun[] @relation("AssistantRunBy")

  agentStatusEvents     AgentStatusEvent[]

  // ── Gallery / Resource Library relations ──
  uploadedResources     Resource[]      @relation("ResourceUploader")
  resourceShares        ResourceShare[] @relation("ResourceSharedBy")
}

// ─────────────────────────────────────────────────────────────────────────────
// Admin AI Assistant — natural-language bulk-ops console (ADMIN-only).
// Every command is PREVIEWED first (no silent writes). On approval it EXECUTES,
// recording the exact before-values per lead so the whole run is REVERSIBLE.
// The assistant may ONLY touch reversible operational fields (ownerId, tags,
// forwardedTeam, followupDate). It can NEVER delete a lead, edit remarks /
// conversation history, or alter historical audit data — those intents are
// refused at parse time. Deleted / recycle-bin leads are always excluded.
// ─────────────────────────────────────────────────────────────────────────────
model AssistantRun {
  id            String    @id @default(cuid())
  command       String                 // raw natural-language text the admin typed
  intent        String                 // QUERY | ASSIGN | TAG | SET_TEAM | SET_FOLLOWUP | UNSUPPORTED
  field         String?                // ownerId | tags | forwardedTeam | followupDate (mutations only)
  parsed        Json                   // full ParsedCommand (filter + action + params + explanation)
  status        String    @default("PREVIEW") // PREVIEW | EXECUTED | UNDONE | FAILED
  affectedCount Int       @default(0)
  affectedIds   Json?                  // string[] of lead ids in scope at preview time
  beforeValues  Json?                  // [{ id, old }] captured at execute time → enables undo
  newValue      String?                // human label of the applied value (e.g. agent name, tag, team)
  error         String?
  createdById   String
  createdBy     User      @relation("AssistantRunBy", fields: [createdById], references: [id])
  createdAt     DateTime  @default(now())
  executedAt    DateTime?
  undoneAt      DateTime?

  @@index([createdById, createdAt])
  @@index([status])
}

// =====================================================
// LEAD SOURCES, STATUSES
// =====================================================

enum LeadSource {
  WEBSITE
  WCR_WEBSITE
  WCR_EVENT
  LANDING_PAGE
  WHATSAPP         // ⚠️ DEPRECATED FOR LEADS — use WEBSITE + medium:"WhatsApp" instead. Kept for IntakeKey backward compat.
  CSV_IMPORT
  EVENT
  REFERRAL
  INBOUND_CALL     // ⚠️ DEPRECATED FOR LEADS — use WEBSITE + medium:"Call" instead. Kept for IntakeKey backward compat.
  FACEBOOK_ADS
  GOOGLE_ADS
  PORTAL_99ACRES
  PORTAL_MAGICBRICKS
  PORTAL_HOUSING
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  SITE_VISIT
  NEGOTIATION
  EOI
  BOOKING_DONE
  WON
  LOST
}

enum AIScore {
  HOT
  WARM
  COLD
}

// Qualification depth — matches Lalit's Dubai-sheet workflow
enum Potential {
  HIGH
  MEDIUM
  LOW
  UNKNOWN
}

enum FundReadiness {
  CASH_READY
  BANK_APPROVED
  FINANCING_NEEDED
  NOT_DISCUSSED
  // MIS-imported values — exact labels from the sheet
  IMMEDIATE_BUYER    // "Immediate Buyer" — funds available, can move quickly
  SHORT_TERM_BUYER   // "Short-Term Buyer" — likely to arrange funds soon
  CONDITIONAL_BUYER  // "Conditional Buyer" — depends on another event (property sale, etc.)
  FINANCED_BUYER     // "Financed Buyer" — requires home loan / financing
  FUTURE_BUYER       // "Future Buyer" — not ready currently
}

enum MoodStatus {
  EXCITED
  INTERESTED
  NEUTRAL
  HESITANT
  COLD
  CONFUSED
  ANGRY
}

enum InvestTimeline {
  IMMEDIATE     // this week
  THIRTY_DAYS
  THREE_MONTHS
  SIX_PLUS_MONTHS
  WINDOW_SHOPPING
  UNKNOWN
}

// BANT qualification verdict — applied AFTER discovery call.
// Budget · Authority · Need · Timeline → Qualifies / Not qualified / Under review.
enum BantStatus {
  UNDER_REVIEW
  QUALIFIES
  NOT_QUALIFIED
}

// Client's earning source — drives messaging tone + EMI eligibility.
enum Profession {
  JOB
  SELF_EMPLOYED
  BUSINESS_OWNER
  INVESTOR
  RETIRED
  STUDENT
  OTHER
}

// Authority — the "A" in BANT. Captures the client's decision power.
// Drives whether to push for site visit, or to involve spouse / family.
enum AuthorityLevel {
  DECISION_MAKER
  INFLUENCER
  GATEKEEPER
  UNKNOWN
}

// Client classification (Lalit ask 2026-06-02) — replaces free-text
// `whoIsClient` as the structured signal. Investor (buying for yield /
// flip), End-user (will live in / use it), Both (mixed motive), Unclear
// (agent hasn't established yet). The free-text `whoIsClient` field stays
// on the Lead model and is repurposed as "client situation / context notes"
// for the long story behind the classification.
enum ClientType {
  INVESTOR
  END_USER
  BOTH
  UNCLEAR
}

// =====================================================
// LEAD — the core entity
// =====================================================

model Lead {
  id              String      @id @default(cuid())
  // contact info
  name            String
  // Second person on the same row — e.g. MIS cell "Soumya, Ayush Gupta" with two
  // phone numbers means family/joint buyer. Both belong to ONE lead (joint inquiry),
  // second name lives here, second phone in altPhone. Lead detail shows both.
  altName         String?
  phone           String?
  // Second number. Many MIS sheets put "+919146449146, 7779990838" into one cell —
  // the importer now splits on `,`/`;`/`/`/newline and stores the extra number here.
  // Lead detail renders separate Call + WhatsApp buttons for it.
  altPhone        String?
  email           String?
  altEmail        String?     // Second email address
  company         String?     // where the client works — matters for HNI profiling
  city            String?
  state           String?     // State / Province — auto-filled from city alongside country
  country         String?
  // true once a user manually edits Country/State → re-enrichment on a later City
  // change must NOT overwrite their value (auto-filled values DO get refreshed).
  locationManual  Boolean     @default(false)
  address         String?     // client's physical address (residence)
  // funnel
  source          LeadSource  @default(WEBSITE)
  sourceDetail    String?     // "marina-may-26" campaign code
  // medium — the communication channel/method (how they came, e.g. "Call", "WhatsApp", "Email")
  // Fixed standards: "Call", "WhatsApp", "Email". Custom mediums stored in mediumOther.
  medium          String?     // "Call" | "WhatsApp" | "Email" | "Other"
  mediumOther     String?     // When medium = "Other", stores the custom name
  status          LeadStatus  @default(NEW)        // = Stage (funnel position)
  currentStatus        String?     // = Status (current state: "Not reached", "Callback today", etc.)
  originalSheetStatus  String?     // raw value from "Status" column during Excel/CSV import
  // requirements
  budgetMin       Float?      // AED for Dubai team
  budgetMax       Float?
  budgetCurrency  String      @default("AED")   // "AED" | "INR" | "UNKNOWN" (UNKNOWN = currency unresolved → show budgetRaw only, admin review)
  budgetRaw       String?     // verbatim imported budget text ("10 Cr", "AED 800K - AED 1M") — display source of truth; never auto-converted
  configuration   String?     // "2BHK" / "Penthouse" / "Plot"
  propertyType    String?     // "Residential" | "Commercial" — auto-filled from project category / configuration, agent+admin editable
  notesShort      String?     // one-liner requirement (legacy)
  remarks         String?     // long remarks (matches sheet's Remarks column) — "Display Remark" (currently == rawRemarks)
  rawRemarks      String?     // IMMUTABLE audit source of truth: exact imported remark text, never transformed, never overwritten after first write. Conversation History "Raw History (Audit Log)" renders this verbatim.
  rawImport       Json?       // IMMUTABLE audit source: the ENTIRE original import row, verbatim (every header→value, incl. mapped columns). Guarantees every imported value — name/phone/email/source/dates/etc. — is recoverable exactly as written, alongside the derived fields. Merged (never value-overwritten by blanks) on re-import.
  sourceRaw       String?     // VERBATIM source value exactly as written in the sheet ("Townscript", "Eventbrite", "Dubai Property Expo This Weekend", "WhatsApp Campaign June"). NEVER mapped/normalized/defaulted. Display + filters + reports use this. The `source` enum below is only a coarse best-effort bucket for legacy charts; sourceRaw is the source of truth.
  tags            String?     // comma-separated for SQLite ("NRI,Investor")
  categorization  String?     // NRI / Resident / Investor / End-user
  language        String?     // "English,Hindi"
  // DEPTH FIELDS (from Dubai sheet — Lalit's priority)
  // `clientType` is the structured "who is the client" signal (3 + 1 options:
  // Investor / End-user / Both / Unclear). Drives messaging, routing, and the
  // Quality Score. `whoIsClient` stays as the free-text "client situation /
  // context notes" — long story behind the classification (e.g. "NRI in Dubai,
  // husband already owns at Burj Vista, parents will relocate next year").
  clientType      ClientType?
  whoIsClient     String?     // FULL client situation context, not keywords
  whenCanInvest   InvestTimeline?
  potential       Potential?
  fundReadiness   FundReadiness?
  moodStatus      MoodStatus?
  // BANT verdict — set after qualification call. Drives the "Qualifies/Not qualified" chip.
  bantStatus      BantStatus  @default(UNDER_REVIEW)
  bantReason      String?     // optional one-liner explaining the verdict
  // BANT depth — real per-letter fields so the BANT card shows true B/A/N/T.
  // B uses budgetMin/Max/Currency + fundReadiness; T uses whenCanInvest.
  // A + N need dedicated columns:
  //   authorityLevel — is the lead the decision-maker, an influencer, or a gatekeeper?
  //   needSummary    — one-line summary of WHY they're buying (move-in, rental yield,
  //                    family relocation, kid's education, etc.).
  authorityLevel       AuthorityLevel?
  authorityPerson      String?   // WHO decides: "Self", "Wife", "Father + Son", "Parents", etc.
  needSummary          String?
  bantSuggestionsJson  String?   // JSON: BantSuggestions (auto-detected from history)
  // Profile depth
  // profession was widened enum Profession -> TEXT (migration 20260623170000)
  // so Sales can type ANY profession. Legacy enum tokens (JOB, SELF_EMPLOYED…)
  // are preserved verbatim as strings. The Profession enum below is kept only
  // for backward reference; this column no longer uses it.
  profession      String?
  linkedInUrl     String?     // full https://linkedin.com/in/... URL
  // Purchase history — captured at intake for cold data or filled after qualification
  alreadyBought   String?     // comma-separated project names client already owns
  alreadyBoughtBy String?     // who they bought it through (broker name or "direct from Emaar")
  detailShared    String?     // what brochures / details we've sent
  photoUrls       String?     // JSON-stringified URLs of uploaded photos
  // scheduling
  meetingDate     DateTime?   // upcoming/last meeting
  siteVisitDate   DateTime?   // upcoming/last site visit
  followupDate    DateTime?   // next follow-up commitment
  todoNext        String?     // free-text "To Do" — what's the next action
  // AI
  aiScore         AIScore?
  aiScoreValue    Int?        // 0-100
  aiSummary       String?     // long-form auto summary
  aiNextAction    String?     // recommended next step
  aiUpdatedAt     DateTime?
  // ownership
  ownerId         String?
  owner           User?       @relation("LeadOwner", fields: [ownerId], references: [id])
  forwardedTeam   String?     // "Dubai" / "India" — canonical team marker. NULL = not yet
                              // classified → ALL automation is suppressed until a team is set
                              // (the mandatory pre-assignment routing gate; see src/lib/teamRouting.ts).
  assignedAt      DateTime?   // when ownerId was last set — for 15-min SLA
  // ── Routing provenance (Lead Routing Architecture) ──
  // Captures HOW/WHY this lead landed on its team, for audit + the lead-detail
  // "routing" display. Set alongside forwardedTeam at intake/assignment time.
  routingMethod   String?     // "manual" | "import" | "rule" | "round_robin_pool" | "admin_queue"
  routingSource   String?     // e.g. "website:dubai-property", "csv:forceTeam", "manual_form", "whatsapp"
  routingReason   String?     // human-readable, e.g. "Dubai property page" / "agent picked India"
  leadOrigin      String      @default("ACTIVE_LEAD") // Phase D: ACTIVE_LEAD (Leads) | REVIVAL (Revival) | MASTER_DATA (repository). Legacy ACTIVE/COLD/PORTFOLIO/SYSTEM still honored during transition.
  // SLA reconciler
  slaFirstCallBy  DateTime?   // ownerId-set + 15 min — escalate if no call by then
  slaEscalated    Boolean     @default(false)  // already notified admin
  // Manager intervention
  needsManagerReview Boolean  @default(false)  // auto-flagged when manager push could help
  managerReviewReason String?                  // why flagged (e.g. "3 not-picked attempts")
  flaggedAt       DateTime?
  // Cold-call bucket — separates outbound cold prospects from real warm leads.
  // Lead lands here when: BANT=NOT_QUALIFIED, OR no contact in 30+ days,
  // OR manager toggles it explicitly. Hides from main /leads list by default.
  isColdCall      Boolean     @default(false)
  coldCallReason  String?
  // dedupe — fingerprint is phone||email hash. Uniqueness is enforced by a
  // PARTIAL unique index ("Lead_fingerprint_active_key") that only covers
  // ACTIVE rows (WHERE "deletedAt" IS NULL), defined in migration
  // 20260611_fingerprint_unique_active. A soft-deleted lead keeps its
  // fingerprint (for audit) but does NOT block re-import of the same contact
  // and does NOT count as a duplicate. The full @unique was intentionally
  // dropped — do NOT re-add it (it would resurrect the deleted-lead dedupe bug).
  fingerprint     String?     // phone||email hash; unique among active leads only
  duplicateCount  Int         @default(0)  // times this client has re-contacted us
  lastDuplicateAt DateTime?

  // ── Import provenance (Import History rollback/delete) ──
  // Stamped on every NEW lead created by a bulk import so an admin can later
  // soft-delete / roll back the entire batch, returning the CRM to its pre-
  // import state. Updated/deduped leads are NOT stamped (they pre-existed) —
  // only the batch's updatedCount records that they were touched.
  importBatchId   String?
  importBatch     ImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  // Soft-delete (used by import rollback). NULL = live. When set, the lead is
  // hidden from every list/count via leadScopeWhere. Reversible — restore
  // clears it. Originals are never hard-deleted (Super-Admin only, future).
  deletedAt       DateTime?
  deletedById     String?
  // Set when the per-lead callback reminder (~10 min before Lead.followupDate) has
  // already fired — prevents the 5-min pre-meeting cron from re-notifying. Cleared
  // when followupDate is edited (handled by the inline-update endpoint).
  followupReminderSentAt DateTime?

  // ── Rejection / Lost-lead capture ──
  // When agent rejects a lead (status → LOST), capture the reason from a
  // fixed dropdown plus optional free-text. Used in /reports/sla and the
  // Pipeline funnel-leakage analysis to understand WHY deals die.
  // rejectionReason one of: FUND_ISSUE / WAR_FEAR / LOW_BUDGET /
  //   LOOK_AFTER_2_YEARS / WAITING_FOR_PROPERTY_SALE / OTHER
  rejectionReason String?
  rejectionNote   String?   // free-text — required when rejectionReason = OTHER
  rejectedAt      DateTime?
  rejectedById    String?

  // ── EOI / Booking workflow (Phase 6 of CRM master spec §13) ──
  // Stage in the booking funnel — populated once a Lead enters NEGOTIATION
  // or beyond. Pipeline UI shows EOI sub-stages once eoiStage is set.
  eoiStage                  String?     // "EOI_DISCUSSED" / "EOI_COLLECTED" / "KYC_PENDING" / "BOOKING_FORM_SENT" / "BOOKING_FORM_SIGNED" / "PAYMENT_PROOF_RECEIVED" / "DEVELOPER_CONFIRMATION" / "BOOKING_DONE"
  eoiAmount                 Int?        // smallest currency unit (paisa / fils)
  eoiCurrency               String?     // "AED" / "INR"
  eoiPaymentMethod          String?     // "BANK_TRANSFER" / "CARD" / "CHEQUE" / "CASH"
  eoiCollectedAt            DateTime?
  kycStatus                 String?     // "PENDING" / "DOCS_RECEIVED" / "VERIFIED" / "REJECTED"
  kycReceivedAt             DateTime?
  bookingFormStatus         String?     // "NOT_SENT" / "SENT" / "SIGNED" / "REJECTED"
  bookingFormSentAt         DateTime?
  bookingFormSignedAt       DateTime?
  paymentProofStatus        String?     // "PENDING" / "RECEIVED" / "VERIFIED"
  paymentProofReceivedAt    DateTime?
  developerConfirmationStatus String?   // "PENDING" / "CONFIRMED"
  developerConfirmedAt      DateTime?
  bookingDoneAt             DateTime?
  // Commission (post-booking).
  commissionAmount          Int?        // smallest currency unit
  commissionCurrency        String?
  commissionStatus          String?     // "PENDING" / "INVOICED" / "RECEIVED"
  commissionReceivedAt      DateTime?
  // Free-text note about discounts / waivers discussed during EOI.
  eoiNotes                  String?
  // Requires manager / admin sign-off before moving forward.
  eoiApprovalRequired       Boolean     @default(false)
  eoiApprovedById           String?
  eoiApprovedAt             DateTime?

  // ── Conditional source fields ──
  // WCR Event source details
  eventName       String?     // event name when source = WCR_EVENT
  eventCountry    String?     // event country
  eventState      String?     // event state / province
  eventCity       String?     // event city
  // Referral source details
  referralName    String?     // referrer's name when source = REFERRAL

  // timestamps
  lastTouchedAt   DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Imported sheet columns with no matching CRM field (original header → value,
  // verbatim). Preserves every Excel column for display + traceability.
  customFields    Json?

  // relations
  interestedUnits LeadProperty[]
  discussed       LeadProject[]
  interestedProjects LeadInterestedProject[]
  activities      Activity[]
  callLogs        CallLog[]
  notes           Note[]
  assignments     Assignment[]
  waMessages      WhatsAppMessage[]
  stickyNotes     StickyNote[]
  fieldHistory    LeadFieldHistory[]
  // Buyer-data conversions that produced THIS lead (normally 0 or 1).
  buyerConversions BuyerRecord[]     @relation("BuyerConvertedLead")
  // Gallery resources shared with this lead (tracking — which file → which client).
  resourceShares  ResourceShare[]   @relation("ResourceShareLead")

  @@index([status])
  @@index([source])
  @@index([ownerId])
  @@index([createdAt])
  @@index([eoiStage])
  @@index([forwardedTeam])
  @@index([importBatchId])
  @@index([deletedAt])
  // Perf (2026-06-22): hot filter/sort/count columns on the Leads page — every
  // follow-up chip count, the status groupBy, the ghosting/overdue filters, and
  // the team/owner scopes. Created on prod via scripts/migrate-lead-indexes.ts
  // (CREATE INDEX CONCURRENTLY — no table lock).
  @@index([followupDate])
  @@index([currentStatus])
  @@index([lastTouchedAt])
  @@index([leadOrigin])
  @@index([ownerId, deletedAt])
  @@index([forwardedTeam, deletedAt])
}

// =====================================================
// LEAD FIELD HISTORY — financial-grade per-field audit trail. One append-only
// row per change to a tracked field (status, budget, BANT, owner/assignment,
// follow-up date, source, leadOrigin/section move, remarks): old→new + who +
// when + where. Makes every change recoverable, "what did X change today" a
// one-query report, and remark text impossible to lose. History accrues
// FORWARD from deploy (past changes can't be reconstructed). Additive table —
// no existing data is touched.
// =====================================================
model LeadFieldHistory {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  field       String   // currentStatus | budgetMin | budgetMax | bantStatus | ownerId | followupDate | source | leadOrigin | remarks | …
  oldValue    String?
  newValue    String?
  changedById String?
  changedBy   User?    @relation("FieldChangedBy", fields: [changedById], references: [id], onDelete: SetNull)
  changedAt   DateTime @default(now())
  source      String?  // inline-edit | bulk | import | eoi | reject | move | system
  @@index([leadId, changedAt])
  @@index([changedById, changedAt])
  @@index([field, changedAt])
}

// =====================================================
// IMPORT BATCH — one row per bulk CSV/Excel import. Drives the ADMIN-ONLY
// Import History screen with per-batch rollback/delete. Stamped onto every NEW
// lead it creates (Lead.importBatchId) so the whole batch can be soft-deleted,
// returning the CRM to its pre-import state. SOFT-DELETE only — leads + the
// batch are marked deleted (reversible), never hard-removed, so the original
// data is always recoverable. Counts mirror the import response shape.
// =====================================================
model ImportBatch {
  id            String    @id @default(cuid())
  fileName      String
  fileSize      Int?
  sheetName     String?
  importType    String?   // leadOrigin written by the import (ACTIVE/COLD/PORTFOLIO)
  team          String?   // admin force-team (Dubai/India) or null
  totalRows     Int       @default(0)
  createdCount  Int       @default(0)   // brand-new leads stamped with this batch (deletable)
  updatedCount  Int       @default(0)   // existing leads updated (deduped) — NOT deletable
  skippedCount  Int       @default(0)
  errorCount    Int       @default(0)
  errors        String?   // JSON array of the first N error strings
  importedById  String?
  importedBy    User?     @relation("ImportBatchImporter", fields: [importedById], references: [id], onDelete: SetNull)
  // Soft-delete / rollback audit trail
  status        String    @default("ACTIVE")  // "ACTIVE" | "DELETED"
  deletedAt     DateTime?
  deletedById   String?
  deletedBy     User?     @relation("ImportBatchDeleter", fields: [deletedById], references: [id], onDelete: SetNull)
  deleteReason  String?
  createdAt     DateTime  @default(now())

  leads         Lead[]

  @@index([importedById])
  @@index([status])
  @@index([createdAt])
}

// =====================================================
// CONVERSATION MODERATION (Lalit-only) — per-remark visibility overlay + audit.
// Imported remarks live as text inside Lead.remarks (no per-row table), so each
// parsed entry is addressed by a stable content hash (remarkParser.remarkKeyFor).
// RemarkVisibility is an OVERLAY — it never edits the original text (the
// Super-Admin backup always retains the full original); it only controls who
// SEES an entry:
//   • deletedFromView   — soft-deleted from the CRM view (restorable)
//   • hiddenFromAll     — hidden from every agent (controllers still see it)
//   • hiddenFromUserIds — CSV of user ids the entry is hidden from (per-agent)
// =====================================================
model RemarkVisibility {
  id                String   @id @default(cuid())
  leadId            String
  remarkKey         String   // stable hash of the parsed remark (date + text)
  deletedFromView   Boolean  @default(false)
  hiddenFromAll     Boolean  @default(false)
  hiddenFromUserIds String?  // CSV of user ids hidden from specific agents
  hiddenFromTeams   String?  // CSV of team names hidden from (e.g. "Dubai,India")
  reason            String?
  updatedById       String?  // who last changed it (plain id — name looked up)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([leadId, remarkKey])
  @@index([leadId])
}

// Append-only audit trail for every conversation-moderation action.
model RemarkAuditLog {
  id            String   @id @default(cuid())
  leadId        String
  remarkKey     String
  action        String   // HIDE_ALL | UNHIDE_ALL | HIDE_AGENT | UNHIDE_AGENT | DELETE | RESTORE
  actorId       String?  // who performed it
  actorName     String?  // denormalized so the log stays readable if the user is renamed
  targetUserId  String?  // for HIDE_AGENT / UNHIDE_AGENT — whom it was hidden from
  targetName    String?
  oldState      String?  // JSON snapshot of visibility before the action
  newState      String?  // JSON snapshot after
  reason        String?
  createdAt     DateTime @default(now())

  @@index([leadId, remarkKey])
  @@index([leadId])
  @@index([createdAt])
}

// =====================================================
// STICKY NOTES — Per-agent private scratchpad pinned to a lead.
// One row per (leadId, userId). The body is the agent's private scratch
// — NEVER expose to other users. Get-or-create on lead-detail render.
// =====================================================
model StickyNote {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String   @default("")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([leadId, userId])
  @@index([userId])
}

// =====================================================
// VAULT — Private agent journal + mood + wins (Phase 3 of CRM master spec §10)
// PRIVACY: entries are visible ONLY to the owning user. Admin sees aggregate
// mood/stress counts via a dedicated query that strips text. Never expose
// `content` to non-owners in any API route or UI.
// =====================================================
model VaultEntry {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Type of entry — separate sections in the UI:
  //   JOURNAL   — daily reflection / general thoughts
  //   VENT      — frustration / blow-off (can auto-expire if expiresAt set)
  //   WIN       — celebration / closing / good moment
  //   LESSON    — insight from a deal / mistake
  //   GRATITUDE — what they're grateful for today
  kind       String
  // Optional mood tag — one of:
  //   "GREAT" | "OK" | "STRESSED" | "OVERWHELMED" | "ANGRY" | "SAD"
  mood       String?
  // Free text. NEVER expose to anyone but the owner.
  content    String
  // Optional comma-separated tags (e.g. "client,negotiation,Mehak")
  tags       String?
  // Optional self-destruct for vents (NULL = persists forever).
  expiresAt  DateTime?
  // AI reflection generated for this entry (cached so the UI doesn't re-prompt).
  aiReflection String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, kind])
}

// =====================================================
// PROPERTIES — Project → Unit → Pricing
// =====================================================

enum ProjectStatus {
  OFF_PLAN
  UNDER_CONSTRUCTION
  READY
  SOLD_OUT
}

// Location enrichment cache — City → Country/State results from OpenStreetMap /
// Nominatim (free, no API key). Curated cityCountry.ts is tried first; this caches
// the long-tail API lookups so we never re-hit Nominatim for the same city.
model LocationCache {
  id        String   @id @default(cuid())
  cityKey   String   @unique          // normalized lowercase city ("greater noida")
  city      String                     // verbatim-ish input for reference
  state     String?
  country   String                     // canonical CRM form (UAE / India / Turkey / UK …)
  source    String   @default("nominatim")  // "nominatim" | "manual"
  createdAt DateTime @default(now())
}

model Project {
  id            String         @id @default(cuid())
  slug          String?        @unique  // stable key for auto-sync from marketing site
  name          String
  developer     String?
  city          String
  area          String?        // "Dubai Marina" / "Sector 42"
  country       String         @default("UAE")
  // Project Master "Status" (owner spec): only ACTIVE projects feed the lead
  // auto-classifier. Set false to retire a project from routing without deleting
  // it. Distinct from `status` below (construction stage OFF_PLAN/READY/…).
  active        Boolean        @default(true)
  status        ProjectStatus  @default(OFF_PLAN)
  handoverDate  DateTime?
  description   String?
  brochureUrl   String?
  imageUrl      String?        // hero image scraped from marketing site
  heroColor     String?        // "from-[#0b1a33] to-[#c9a24b]" tailwind gradient
  rera          String?
  category      String?        // "residential" | "commercial"
  source        String?        // "manual" | "wcr-website" — provenance
  syncedAt      DateTime?      // last time auto-sync touched this row
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  units         Unit[]
  discussedBy   LeadProject[]
  interestedInBy LeadInterestedProject[]

  @@index([city])
  @@index([status])
}

// Projects DISCUSSED with a lead (different from interestedUnits which pins specific units)
enum LeadProjectStatus {
  DISCUSSED       // mentioned/sent brochure
  SHORTLISTED     // serious interest
  SITE_VISITED
  RULED_OUT
}

model LeadProject {
  id        String            @id @default(cuid())
  leadId    String
  projectId String
  status    LeadProjectStatus @default(DISCUSSED)
  notes     String?
  discussedAt DateTime        @default(now())
  // Auto-detection source tracking
  autoDetected Boolean        @default(false)
  sourceType   String?        // "REMARK" | "CALL_NOTE" | "WA_MESSAGE" | "NOTE" | "MANUAL"
  sourceDate   DateTime?
  sourceText   String?        // ≤200-char excerpt from source text
  suggestion   Boolean        @default(false) // true = auto-detected, pending accept/reject
  lead      Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@unique([leadId, projectId])
  @@index([leadId])
  @@index([projectId])
}

// "Interested Properties" — a SEPARATE, independent store from LeadProject
// ("Properties Discussed"). Same project-picker toolkit (search / scan / manual),
// but its own table so the two lists never affect each other: a client may have
// discussed 10 projects yet be interested in only 2. Purely additive — no existing
// query reads or writes LeadProject because of this model.
model LeadInterestedProject {
  id           String    @id @default(cuid())
  leadId       String
  projectId    String
  notes        String?
  autoDetected Boolean   @default(false)
  sourceType   String?   // "REMARK" | "CALL_NOTE" | "WA_MESSAGE" | "NOTE" | "MANUAL"
  sourceDate   DateTime?
  sourceText   String?   // ≤200-char excerpt from source text
  suggestion   Boolean   @default(false) // true = auto-detected via Scan, pending accept/reject
  interestedAt DateTime  @default(now())
  lead    Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@unique([leadId, projectId])
  @@index([leadId])
  @@index([projectId])
}

// Project mentions in lead text that didn't match any known project.
// Admin/Manager can link to an existing project, create a new one, or ignore.
model UnmatchedMention {
  id                String    @id @default(cuid())
  leadId            String
  mentionText       String    // the project-like phrase extracted from text
  sourceType        String    // "REMARK" | "CALL_NOTE" | "WA_MESSAGE" | "NOTE"
  sourceDate        DateTime?
  sourceText        String?   // ~150-char excerpt for context
  resolved          Boolean   @default(false)
  resolvedProjectId String?   // linked Project.id (if admin linked it)
  resolvedIgnored   Boolean   @default(false)
  createdAt         DateTime  @default(now())
  @@index([leadId])
  @@index([resolved])
}

// Free-text property interest notes — auto-detected from lead text or manually added.
// Separate from LeadProperty (which requires an actual Unit record).
// Example: "Client interested in 2BR Business Bay under AED 2M"
model LeadInterestNote {
  id            String    @id @default(cuid())
  leadId        String
  noteText      String    // human-readable interest summary
  autoDetected  Boolean   @default(false)
  sourceType    String?
  sourceDate    DateTime?
  matchedUnitId String?   // set if a specific Unit was found for this interest
  createdAt     DateTime  @default(now())
  @@index([leadId])
}

enum UnitStatus {
  AVAILABLE
  HOLD
  BOOKED
  SOLD
}

model Unit {
  id              String      @id @default(cuid())
  projectId       String
  project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code            String      // "T-B-1804" tower-block-flat
  configuration   String      // "2BHK" / "Studio" / "PH"
  carpetArea      Float?      // sqft
  builtUpArea     Float?
  floor           Int?
  view            String?
  priceBase       Float
  priceFinal      Float?
  status          UnitStatus  @default(AVAILABLE)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  interestedBy    LeadProperty[]

  @@unique([projectId, code])
  @@index([status])
}

enum LeadInterestType {
  PRIMARY
  COMPARE
  RULED_OUT
}

model LeadProperty {
  id        String           @id @default(cuid())
  leadId    String
  unitId    String
  type      LeadInterestType @default(PRIMARY)
  notes     String?
  createdAt DateTime         @default(now())

  lead      Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  unit      Unit             @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([leadId, unitId])
}

// =====================================================
// ACTIVITIES, CALLS, NOTES, WA MESSAGES
// =====================================================

enum ActivityType {
  CALL
  WHATSAPP
  EMAIL
  SITE_VISIT
  OFFICE_MEETING
  VIRTUAL_MEETING
  HOME_VISIT          // India team — agent visits client at home
  EXPO_MEETING        // Dubai team — meets prospect at a developer Expo (held in IN cities)
  COLD_TO_LEAD        // Logged when agent promotes a cold-data row to a real lead
  MEETING             // legacy — kept for backwards compatibility
  TASK
  NOTE
  STATUS_CHANGE
  ASSIGNMENT
  LEAD_CREATED
  BROCHURE_SENT
  PROJECT_DISCUSSED
  REMINDER_FIRED
}

enum ActivityStatus {
  PLANNED
  DONE
  OVERDUE
  CANCELLED
}

model Activity {
  id          String         @id @default(cuid())
  leadId      String
  lead        Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?          @relation(fields: [userId], references: [id])
  type        ActivityType
  status      ActivityStatus @default(PLANNED)
  title       String
  description String?
  scheduledAt DateTime?
  completedAt DateTime?
  // ── Smart Timeline edit fields (admin-editable per-entry) ──
  /// Free-text outcome label for this event (e.g. "Connected", "Site visit done").
  /// Optional — set when an admin edits the entry or a logger captures an outcome.
  outcome     String?
  /// Per-entry follow-up date. When an admin edits a timeline entry and it maps to
  /// a follow-up, this is updated AND mirrored onto Lead.followupDate.
  followupDate DateTime?
  // ── Visit/meeting attendance + live-tracking (SITE_VISIT, OFFICE_MEETING, VIRTUAL_MEETING) ──
  /// Who actually attended (may differ from `userId`/owner — e.g. agent sent a colleague)
  attendedByUserId   String?
  /// Comma-separated user ids of co-attendees (joint visits)
  additionalAttendees String?
  /// Number of times this activity was rescheduled (incremented when scheduledAt changes pre-completion)
  rescheduledCount   Int       @default(0)
  /// True if nobody showed up (used in SLA report)
  isNoShow           Boolean   @default(false)
  /// Live-tracking — captured when agent taps "Start Site Visit"
  startedAt          DateTime?
  startedLat         Float?
  startedLng         Float?
  endedAt            DateTime?
  endedLat           Float?
  endedLng           Float?
  /// JSON-stringified [{ts, lat, lng}, …] — polled every 60s between Start and End
  locationTrack      String?
  /// When the 30-min-before pre-meeting reminder fired (dedupe for the 5-min cron)
  reminderSentAt     DateTime?
  /// When the 1-HOUR-before reminder fired (agent + manager) — separate dedupe flag
  reminderSentAt1h   DateTime?
  // ── Expo meeting fields (Dubai team — meets prospects at developer expos in IN cities) ──
  expoCity            String?    // "Gurgaon", "Delhi", "Mumbai", "Bangalore"
  expoHotel           String?    // venue name
  expoDeveloper       String?    // which developer hosted (Emaar / Sobha / DLF…)
  expoDeveloperContact String?   // developer's salesperson name we coordinated with
  expoAgentAttended   Boolean   @default(false) // did our agent travel + attend in person?
  // ── Dubai site-visit fields (we don't have an office in Dubai, so coordination matters) ──
  dubaiDeveloperSalesperson String?
  cabScheduled       Boolean    @default(false)
  decisionInOffice   Boolean    @default(false) // did client decide on the spot at developer office
  // ── India travel reimbursement (auto-calculated from distanceKm * per-km rate) ──
  distanceKm           Float?
  reimbursementAmount  Float?    // INR, computed at log time using Setting.travelPerKmInr
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  edits       ActivityEdit[]

  @@index([leadId])
  @@index([scheduledAt])
  @@index([status])
  @@index([type, completedAt])
}

// =====================================================
// ACTIVITY EDIT — append-only audit trail for Smart Timeline edits.
// When an ADMIN / Super-Admin edits a timeline Activity (date/time/type/outcome/
// remark text/follow-up), the prior value is preserved here per changed field
// (old → new + who + when). The Smart Timeline shows the LATEST Activity value;
// this table retains the full edit history. NO timeline data is ever lost — the
// entry is updated in place and the prior value is captured here.
// =====================================================
model ActivityEdit {
  id          String   @id @default(cuid())
  activityId  String
  activity    Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  leadId      String   // denormalized for fast per-lead audit queries
  field       String   // "type" | "outcome" | "description" | "scheduledAt" | "completedAt" | "followupDate"
  oldValue    String?
  newValue    String?
  editedById  String?
  editedBy    User?    @relation("ActivityEditedBy", fields: [editedById], references: [id], onDelete: SetNull)
  editedByName String? // denormalized so the log stays readable if the user is renamed
  createdAt   DateTime @default(now())

  @@index([activityId])
  @@index([leadId, createdAt])
  @@index([editedById, createdAt])
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallOutcome {
  CONNECTED
  NOT_PICKED
  CALLBACK
  WRONG_NUMBER
  BUSY
  SWITCHED_OFF
  INTERESTED
  NOT_INTERESTED
}

model CallLog {
  id           String         @id @default(cuid())
  leadId       String?
  lead         Lead?          @relation(fields: [leadId], references: [id])
  userId       String
  user         User           @relation(fields: [userId], references: [id])
  direction    CallDirection  @default(OUTBOUND)
  phoneNumber  String
  durationSec  Int?
  outcome      CallOutcome
  notes        String?
  // When a CallLog was created from a MIS-import remark cell, the actual person
  // who made the call is in the remark text (e.g. "Nitisha: on 16 May..."). The
  // importer-as-user (often the admin) is wrong for display. Set this column
  // to the parsed agent name so the call history shows WHO actually called
  // rather than who imported the sheet.
  // Null when an agent logs a call live in the UI (user.name is correct then).
  attributedAgentName String?
  // IVR-ready fields
  ivrProvider  String?        // "exotel" / "knowlarity" / "myoperator" / null for manual
  ivrCallId    String?        @unique
  recordingUrl String?
  startedAt    DateTime       @default(now())
  endedAt      DateTime?
  createdAt    DateTime       @default(now())

  @@index([leadId])
  @@index([userId])
  @@index([startedAt])
}

model Note {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  body      String
  // Raw speech-to-text transcript for VOICE notes (audit). body holds the
  // auto-corrected text shown to users; voiceOriginal preserves what was spoken.
  voiceOriginal String?
  createdAt DateTime @default(now())

  @@index([leadId])
}

enum WAMessageDirection {
  INBOUND
  OUTBOUND
}

model WhatsAppMessage {
  id          String              @id @default(cuid())
  leadId      String?
  lead        Lead?               @relation(fields: [leadId], references: [id])
  phoneNumber String
  direction   WAMessageDirection
  body        String
  templateId  String?
  providerMsgId String?           @unique
  receivedAt  DateTime            @default(now())

  @@index([phoneNumber])
  @@index([leadId])
}

// =====================================================
// ASSIGNMENT HISTORY (for distribution audit)
// =====================================================

model Assignment {
  id         String   @id @default(cuid())
  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  reason     String?  // "round-robin" / "manual" / "rule:dubai"
  assignedAt DateTime @default(now())
  @@index([leadId])
  @@index([userId])
}

// =====================================================
// AUDIT LOG
// =====================================================

// ──────────────────────────────────────────────────────────
// DAILY MOOD — end-of-day check-in (optional, max one per agent per day)
// Drives: team-mood widget for admin + culture trend over time.
// ──────────────────────────────────────────────────────────
enum Mood {
  FRUSTRATING   // 😣
  NOT_GREAT     // 🙁
  MIXED         // 😐
  LOOKS_GOOD    // 🙂
  AWESOME       // 😍
}

model DailyMood {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date     // truncated to day
  mood      Mood
  comment   String?               // optional follow-up answer
  createdAt DateTime @default(now())
  @@unique([userId, date])
  @@index([date])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String   // "lead.create", "lead.assign", "user.invite"
  entity    String   // "Lead" / "User" / ...
  entityId  String?
  meta      String?  // JSON-stringified extras (SQLite has no JSON type)
  createdAt DateTime @default(now())
  @@index([entity, entityId])
  @@index([createdAt])
}

// =====================================================
// DEVICE SECURITY — trusted-device binding + sessions
// =====================================================

model Device {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId     String    // client-generated UUID kept in the browser's localStorage
  name         String    // e.g. "Mehak – Chrome Windows" / "Mehak – iPhone"
  type         String    @default("desktop") // mobile | desktop | tablet
  browser      String?
  os           String?
  firstIp      String?
  lastIp       String?
  lastCity     String?
  lastCountry  String?
  status       String    @default("PENDING") // PENDING | APPROVED | BLOCKED
  approvedById String?
  approvedBy   User?     @relation("DeviceApprover", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  createdAt    DateTime  @default(now())
  lastSeenAt   DateTime  @default(now())
  sessions     UserSession[]
  @@unique([userId, deviceId])
  @@index([userId])
  @@index([status])
}

model UserSession {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceRef     String?   // Device.id
  device        Device?   @relation(fields: [deviceRef], references: [id], onDelete: SetNull)
  ip            String?
  city          String?
  country       String?
  userAgent     String?
  createdAt     DateTime  @default(now()) // login time
  lastActiveAt  DateTime  @default(now())
  expiresAt     DateTime
  revokedAt     DateTime?
  revokedReason String?
  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

// =====================================================
// INTAKE API KEYS (for website + WhatsApp webhooks)
// =====================================================

model IntakeKey {
  id        String     @id @default(cuid())
  label     String
  key       String     @unique
  source    LeadSource
  active    Boolean    @default(true)
  hrScope   Boolean    @default(false)  // true = authorizes the HR intake endpoint (/api/intake/hr), not Sales
  createdAt DateTime   @default(now())
  lastUsed  DateTime?
}

// =====================================================
// SETTINGS (singleton key-value)
// =====================================================

model Setting {
  key   String @id
  value String
}

// ──────────────────────────────────────────────────────────
// MESSAGE TEMPLATES — WhatsApp + Email library with placeholders.
// Placeholders auto-substituted at send time:
//   {{name}}      → lead first name
//   {{fullname}}  → lead full name
//   {{agent}}     → sender's first name
//   {{project}}   → first interested project name (if any)
//   {{budget}}    → formatted budget min (e.g. "AED 2.5M")
//   {{phone}}     → lead phone (E.164)
// Trigger lets the picker auto-suggest the right template for the stage.
// ──────────────────────────────────────────────────────────
enum TemplateKind {
  WHATSAPP
  EMAIL
}

enum TemplateTrigger {
  FIRST_QUERY        // brand-new lead, first ever contact
  AFTER_CALL         // just had a call, sending follow-up
  AFTER_NOT_PICKED   // 1+ missed-call attempts, re-engage
  SCHEDULE_VISIT     // book a site visit
  POST_VISIT         // after the site visit
  NEGOTIATION        // discussing price / payment plan
  REENGAGE_COLD      // dormant for weeks, fresh nudge
  GENERIC            // catch-all
}

model Template {
  id          String          @id @default(cuid())
  kind        TemplateKind
  name        String
  trigger     TemplateTrigger @default(GENERIC)
  subject     String?         // only used for EMAIL
  body        String          @db.Text
  active      Boolean         @default(true)
  createdById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([kind, active])
  @@index([trigger])
}

// ──────────────────────────────────────────────────────────
// SAVED FILTERS — named views on /leads. Store the URL query string
// (e.g. "ai=HOT&team=Dubai") and re-apply with one click. Shared filters
// visible to whole team; private ones only to the creator.
// ──────────────────────────────────────────────────────────
model SavedFilter {
  id          String   @id @default(cuid())
  name        String
  queryString String   @db.Text   // e.g. "ai=HOT&team=Dubai&sort=touched_asc"
  icon        String?              // emoji, e.g. "🔥"
  createdById String?              // null = system seed (visible to all, only admin can delete)
  isShared    Boolean  @default(true) // visible to whole team if true
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdById])
  @@index([isShared, sortOrder])
}

// ──────────────────────────────────────────────────────────
// WORKFLOW ENGINE — Zoho-style rules + drip campaigns.
//
// A Workflow has one TRIGGER + an ordered list of ACTIONS. When the trigger
// fires for a lead, the engine queues every action (some immediate, some
// delayed). A delayed action waits until its `runAt` time, then a cron sweep
// dispatches it. WorkflowRun rows track which workflow×lead pairs have already
// fired (idempotency) plus pending vs done state for delayed actions.
// ──────────────────────────────────────────────────────────
enum WorkflowTrigger {
  LEAD_CREATED         // new lead intake
  STATUS_CHANGED       // lead.status moved
  BANT_CHANGED         // BANT verdict set (Qualifies / Not qualified)
  STAGE_TIME           // X minutes in a specific stage
  NO_CONTACT_DAYS      // No call/WA/email in N days
  NOT_PICKED_STREAK    // N consecutive NOT_PICKED outcomes
  COLD_PROMOTED        // Cold-data → Lead promotion
}

enum WorkflowActionType {
  SEND_WA              // Send WhatsApp template (config.templateId)
  SEND_EMAIL           // Send email template (config.templateId)
  CREATE_TASK          // Create planned Activity for the owner (config: title, dueInMinutes)
  NOTIFY_ADMIN         // In-app + email notification to Admin/Manager
  NOTIFY_OWNER         // In-app notification to lead's owner
  SET_FIELD            // Set Lead field (config: field, value)
  ADD_TAG              // Append to Lead.tags (config: tag)
}

enum WorkflowRunStatus {
  PENDING              // queued, waiting for runAt
  RUNNING
  DONE
  FAILED
  SKIPPED              // condition no longer met when dispatcher ran
}

model Workflow {
  id            String           @id @default(cuid())
  name          String
  description   String?
  trigger       WorkflowTrigger
  triggerConfig String?          @db.Text  // JSON — { status?: "NEW", days?: 7, etc. }
  /// "Only fire if lead matches this query string" — e.g. "team=Dubai&ai=HOT"
  /// Empty = applies to every lead.
  filterQuery   String?
  active        Boolean          @default(true)
  createdById   String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  actions       WorkflowAction[]
  runs          WorkflowRun[]

  @@index([trigger, active])
}

model WorkflowAction {
  id           String             @id @default(cuid())
  workflowId   String
  workflow     Workflow           @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  sequenceOrder Int               @default(0)
  type         WorkflowActionType
  config       String             @db.Text  // JSON
  /// 0 = run immediately. >0 = schedule for runAt = trigger time + delayMinutes.
  delayMinutes Int                @default(0)

  runs         WorkflowRun[]

  @@index([workflowId, sequenceOrder])
}

model WorkflowRun {
  id           String             @id @default(cuid())
  workflowId   String
  workflow     Workflow           @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  actionId     String?            // null = the "trigger fired" master row (one per workflow+lead+triggerEvent)
  action       WorkflowAction?    @relation(fields: [actionId], references: [id], onDelete: Cascade)
  leadId       String
  status       WorkflowRunStatus  @default(PENDING)
  runAt        DateTime           // when to dispatch this action (now() for immediate, future for delayed)
  startedAt    DateTime?
  finishedAt   DateTime?
  error        String?            @db.Text
  /// Idempotency dedupe key — same trigger+lead+actionId should never fire twice.
  /// Built like "<workflowId>:<leadId>:<actionId>:<eventTs>" for delays, or "<workflowId>:<leadId>" for once-only.
  dedupeKey    String             @unique
  createdAt    DateTime           @default(now())

  @@index([status, runAt])
  @@index([leadId])
}

// =====================================================
// NOTIFICATIONS — in-app bell + per-user inbox
// =====================================================

enum NotifKind {
  LEAD_ASSIGNED       // your lead arrived
  LEAD_DUPLICATE      // an existing lead re-contacted
  CALL_SLA_BREACH     // 15 min passed, no call logged
  AUTO_ASSIGN_FIRED   // 5 min, admin didn't assign — auto-assigned
  REMINDER            // generic follow-up reminder
  SYSTEM              // info / settings change
  LUNCH_REMINDER      // soft lunch-break reminder (2:00 / 2:25 PM IST)
  AGENT_STATUS        // field-movement check-in (I'm here / meeting / site visit) → manager
  BUYER_ASSIGNED      // a Buyer-Data record was assigned/transferred to you (≠ a lead)
  BUYER_CONVERTED     // a buyer was converted into a real Lead
  BUYER_RETURNED      // a buyer was returned to the Admin Buyer Pool (manual reject OR auto-5-attempts)
}

enum NotifSeverity {
  INFO
  WARNING
  CRITICAL
}

model Notification {
  id        String        @id @default(cuid())
  userId    String        // recipient
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      NotifKind
  severity  NotifSeverity @default(INFO)
  title     String
  body      String?
  linkUrl   String?       // where clicking it takes you (e.g. /leads/abc)
  leadId    String?       // optional related lead
  readAt    DateTime?     // null = unread
  // When set + in the future, the notification is hidden from the inbox until that time.
  // Cleared automatically by simply letting the timestamp pass (no cron needed — queries
  // filter `snoozedUntil > now`).
  snoozedUntil DateTime?
  createdAt DateTime      @default(now())
  @@index([userId, readAt])
  @@index([createdAt])
}

// =====================================================
// WEB PUSH — browser push notifications to phone / desktop
// =====================================================

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   // who is subscribed
  endpoint  String   @unique  // browser-issued URL
  p256dh    String   // encryption pubkey
  authKey   String   // auth secret
  userAgent String?  // for debugging which device
  createdAt DateTime @default(now())
  @@index([userId])
}

// =====================================================
// CUSTOM FIELDS — admin can add new fields per entity, no code
// =====================================================

enum CustomFieldKind {
  TEXT
  TEXTAREA
  NUMBER
  DATE
  SELECT
  CHECKBOX
}

enum CustomFieldEntity {
  LEAD
  PROJECT
}

model CustomField {
  id         String            @id @default(cuid())
  entity     CustomFieldEntity
  key        String
  label      String
  kind       CustomFieldKind   @default(TEXT)
  options    String?
  required   Boolean           @default(false)
  position   Int               @default(0)
  active     Boolean           @default(true)
  createdAt  DateTime          @default(now())
  values     CustomFieldValue[]
  @@unique([entity, key])
}

model CustomFieldValue {
  id        String      @id @default(cuid())
  fieldId   String
