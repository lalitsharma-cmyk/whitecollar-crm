// =====================================================
// AGENT ATTENDANCE — login/logout tracking
// =====================================================

model AttendanceLog {
  id        String   @id @default(cuid())
  userId    String
  loginAt   DateTime @default(now())
  logoutAt  DateTime?
  ip        String?
  userAgent String?
  @@index([userId, loginAt])
}

// Daily attendance — drives round-robin (only PRESENT/LATE agents get leads).
// One row per agent per day. Auto-set on first login (PRESENT if before 10:30am,
// LATE after), can be admin-overridden.
enum AttendanceStatus {
  PRESENT     // logged in by 10:30am
  LATE        // logged in 10:30am-7pm
  ABSENT      // never logged in (or admin marked)
  ON_LEAVE    // admin marked — planned leave
}

model Attendance {
  id        String           @id @default(cuid())
  userId    String
  date      DateTime         @db.Date
  status    AttendanceStatus @default(PRESENT)
  markedAt  DateTime         @default(now())
  markedBy  String?          // null = self-mark / auto, else admin userId
  notes     String?
  // ── "I am here" agent self-check-in (distinct from the login auto-mark) ──
  // Set when the agent taps the "I'm here" button on their dashboard. The card
  // shows until this is set, then hides for the rest of the IST day; a new date
  // row next day resets it. checkInIp / checkInDevice captured at that tap.
  selfCheckedInAt DateTime?
  checkInIp       String?
  checkInDevice   String?
  @@unique([userId, date])
  @@index([date])
}

// =====================================================
// AGENT FIELD-MOVEMENT STATUS — agents tap a button on their phone to log
// where they are: arrived / left office / going-or-back-from a meeting or
// site visit. Manager (Lalit) is notified on every event, with the duration
// computed on the "Returned" tap. Distinct from Attendance (1 row/day, drives
// round-robin); this is an append-only event log (many rows/day).
//
// PAIR MODEL — start/end events are linked on the row that CLOSES them:
//   • A "Going …" event is created OPEN (endedAt = null, durationMin = null).
//   • The matching "Returned …" event is created CLOSED at the same instant
//     (endedAt = startedAt) AND back-fills the open "Going" row's endedAt +
//     durationMin (so the opening row carries the duration too, and is no
//     longer "open"). The "Returned" row stores the same durationMin + a
//     pairedEventId pointing back at the "Going" row it closed.
//   • HERE / LEAVING_OFFICE are standalone point events (always closed,
//     durationMin = null).
// "Currently OUT" = a GOING_* row with endedAt IS NULL.
// =====================================================
enum AgentStatusKind {
  HERE                 // "I Am Here" — arrival / check-in (also marks Attendance self-check-in)
  LEAVING_OFFICE       // left the office for the day
  GOING_MEETING        // heading out to a meeting (start)
  RETURNED_MEETING     // back from the meeting (end → duration)
  GOING_SITE_VISIT     // heading out to a site visit (start)
  RETURNED_SITE_VISIT  // back from the site visit (end → duration)
}

model AgentStatusEvent {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  status        AgentStatusKind
  startedAt     DateTime        @default(now())
  endedAt       DateTime?       // set on the closing ("Returned") row AND back-filled onto the opening ("Going") row
  durationMin   Int?            // minutes between the Going start and the Returned tap (on both paired rows)
  pairedEventId String?         // on a "Returned" row → the id of the "Going" row it closed
  note          String?
  createdAt     DateTime        @default(now())
  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([userId, status, endedAt]) // fast "open Going event for this user" lookup
}

// =====================================================
// CRON RUN — per-execution health log for /api/cron/* jobs
// Lets admins (and Lalit's helpers) verify each scheduled job ran
// today on the /admin/cron-health page.
// =====================================================
model CronRun {
  id         String    @id @default(cuid())
  name       String    // e.g. "morning-reminder"
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  status     String    // "OK" | "ERROR" | "RUNNING"
  error      String?
  meta       String?   // JSON string for extra context
  @@index([name, startedAt])
}

// =====================================================
// AI TRIAL MODE + USAGE TRACKING
// (AI kill-switch / trial-before-full-run spec — Lalit 2026-06-03)
//
// Before AI is unleashed on the full ~25k-lead DB it is piloted on a small,
// admin-selected sample so we can judge output quality + real token cost first.
//   • AiTrialRun  — one pilot batch: selection, live progress, cost aggregates.
//   • AiTrialItem — one (lead × feature) result inside a run, kept for manual
//                   quality review and for the "clear trial outputs" control.
//   • AiUsageLog  — every REAL provider call (trial or live); the source of
//                   truth for the AI usage/cost dashboard. Written ONLY when an
//                   actual API request is sent (never on page load / cached read).
// All additive. The global kill-switch + trial-mode flags live in Setting
// (keys "ai.enabled" / "ai.trialMode.enabled"), NOT here.
// =====================================================
enum AiTrialStatus {
  DRAFT      // created + cost-estimated, awaiting admin confirm
  RUNNING
  PAUSED     // admin paused — completed items kept, resumable
  STOPPED    // admin stopped — partial results kept, NOT auto-resumed
  DONE
  FAILED
}

model AiTrialRun {
  id              String        @id @default(cuid())
  status          AiTrialStatus @default(DRAFT)
  // ── selection ──
  sampleSize      Int           // 10 / 25 / 50 / 100 (or custom)
  team            String?       // "India" | "Dubai" | null = all teams
  source          String?       // Lead.source filter | null = any source
  features        String        // CSV of feature keys: summary,score,nextAction,waDraft,coldRevival,propertyMatch
  // ── provider snapshot (captured at run start) ──
  provider        String?       // "gemini" | "anthropic"
  model           String?       // resolved model id
  // ── live progress ──
  totalLeads      Int           @default(0)
  processed       Int           @default(0)
  failed          Int           @default(0)
  // ── usage / cost (tokens as ints; cost in MICRO-USD to avoid float drift) ──
  inputTokens     Int           @default(0)
  outputTokens    Int           @default(0)
  estCostMicroUsd Int?          // pre-run estimate shown for confirmation
  costMicroUsd    Int           @default(0)   // actual accumulated
  totalMs         Int           @default(0)   // summed processing time
  // ── control / audit ──
  createdById     String?       // admin who created it (User.id; no FK so history survives user removal)
  confirmedAt     DateTime?     // admin confirmed the estimate → allowed to run
  startedAt       DateTime?
  finishedAt      DateTime?
  qualityNote     String?       // admin's post-review notes (good / bad / too generic / …)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  items           AiTrialItem[]

  @@index([status])
  @@index([createdAt])
}

model AiTrialItem {
  id           String     @id @default(cuid())
  runId        String
  run          AiTrialRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  leadId       String     // Lead.id (no FK — a deleted lead must not block trial history)
  feature      String     // which feature this row is for
  status       String     // "PENDING" | "DONE" | "FAILED" | "SKIPPED"
  inputTokens  Int        @default(0)
  outputTokens Int        @default(0)
  costMicroUsd Int        @default(0)
  ms           Int?       // processing time for this item
  output       String?    // generated text, kept for manual quality review
  error        String?
  createdAt    DateTime   @default(now())

  @@index([runId])
  @@index([leadId])
}

model AiUsageLog {
  id           String   @id @default(cuid())
  provider     String   // "gemini" | "anthropic"
  model        String
  feature      String?  // logical feature: "score" | "summary" | "chat" | "trial" | …
  leadId       String?  // when tied to a specific lead
  trialRunId   String?  // when part of a trial run
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  costMicroUsd Int      @default(0)
  ms           Int?
  ok           Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([feature])
}

// ── AI COPILOT PILOT — GPT-4.1-mini per-lead analysis (Lalit's leads only) ──
// AiAnalysis: one row per "Analyze Lead" / "Re-analyze" click.
// resultJson stores the full structured JSON from GPT (see ai-openai.ts for schema).
// NEVER modifies CRM fields automatically — output is always suggestion-only.
model AiAnalysis {
  id            String   @id @default(cuid())
  leadId        String
  triggeredBy   String   @default("manual") // "manual" | "re-analyze"
  triggeredById String?  // User.id who clicked (no FK — admin removal must not cascade)
  resultJson    String   @db.Text  // serialised AiAnalysisResult JSON
  model         String   @default("gpt-4.1-mini")
  inputTokens   Int      @default(0)
  outputTokens  Int      @default(0)
  costMicroUsd  Int      @default(0)
  ok            Boolean  @default(true)
  error         String?
  createdAt     DateTime @default(now())

  feedbacks     AiSuggestionFeedback[]

  @@index([leadId, createdAt])
}

// One row per Accept/Edit/Reject action on an AI-suggested field value.
// Builds the "AI Learning Layer" — Lalit's corrections inform prompt improvement.
model AiSuggestionFeedback {
  id           String     @id @default(cuid())
  analysisId   String
  analysis     AiAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  leadId       String
  fieldName    String     // "budget" | "authority" | "meetingStatus" | "nextAction" | …
  aiValue      String     @db.Text  // what GPT suggested
  action       String     // "ACCEPT" | "EDIT" | "REJECT"
  editedValue  String?    @db.Text  // if EDIT, the corrected value
  userId       String?    // who acted
  createdAt    DateTime   @default(now())

  @@index([analysisId])
  @@index([leadId])
  @@index([fieldName, action])
}

// ── AI EXTRACTION — per-lead structured field extraction ─────────────────
// Each row is one extraction run (triggered manually or after an activity).
// resultJson holds a serialised AIExtractionResult so the schema stays stable
// as extracted fields evolve. Auto-apply is gated by the Setting key
// "ai.extraction.autoApply" (default "false") so Lalit can review quality
// on 20 sample leads before enabling batch auto-fill.
model AiExtraction {
  id           String   @id @default(cuid())
  leadId       String
  resultJson   String   @db.Text   // serialised AIExtractionResult JSON
  triggeredBy  String   @default("manual") // call_log|wa_message|voice_note|meeting_note|import|manual
  provider     String?
  model        String?
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  costMicroUsd Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([leadId, createdAt])
}

// ── Customer Intelligence System (pre-assignment check) ───────────────────
// Master customer profile consolidating identity across all data sources.
// Created/updated when a STRONG match is confirmed.
model CustomerProfile {
  id               String    @id @default(cuid())
  name             String
  primaryPhone     String?
  secondaryPhone   String?
  whatsappPhone    String?
  email            String?
  city             String?
  company          String?
  isInvestor       Boolean?
  totalProperties  Int       @default(0)
  totalTxValueAed  Int       @default(0)
  previousProjects String    @default("[]") // JSON string[]
  previousAgents   String    @default("[]") // JSON string[]
  firstSeenAt      DateTime  @default(now())
  lastInteractedAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  matches   IntelligenceMatch[]
  portfolio PropertyPortfolio[]

  @@index([primaryPhone])
  @@index([email])
  @@index([name])
}

enum MatchType {
  STRONG
  MEDIUM
  WEAK
  NONE
}

// One per Lead — pre-assignment intelligence check result.
// Populated BEFORE round-robin / SLA / automation runs.
// leadId is a loose string reference (no FK) — no cascades needed.
model IntelligenceMatch {
  id               String           @id @default(cuid())
  leadId           String?          @unique
  profileId        String?
  profile          CustomerProfile? @relation(fields: [profileId], references: [id])

  matchType            MatchType  @default(NONE)
  confidence           Int        @default(0)    // 0–100
  matchedBy            String     @default("[]") // JSON [{field,value,source,recordId}]
  historyJson          String     @default("[]") // JSON full previous timeline
  previousAgentName    String?
  previousStatus       String?
  lastContactAt        DateTime?
  totalRecordsFound    Int        @default(0)
  totalPropertiesFound Int        @default(0)

  // Project-to-project comparison
  projectMatch  String?  // "SAME_PROJECT" | "DIFFERENT_PROJECT" | "EXISTING_BUYER"
  projectNote   String?

  // AI summary (generated after match when AI enabled)
  aiSummary        String?
  suggestedApproach String?
  aiCheckedAt      DateTime?

  checkedAt DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([profileId])
}

// Imported property buyer / investor records (Section 11 columns).
// Phone-matched to CustomerProfile on import.
model PropertyPortfolio {
  id                  String           @id @default(cuid())
  profileId           String?
  profile             CustomerProfile? @relation(fields: [profileId], references: [id])

  date                DateTime?
  project             String
  tower               String?
  unit                String?
  bedrooms            String?
  transactionValueAed Int?
  actualSizeSqft      Int?
  ownerName           String
  primaryPhone        String?
  secondaryPhone      String?
  agentName           String?
  status              String?
  followUpDate        DateTime?
  remarks             String?
  importSource        String?

  createdAt DateTime @default(now())

  @@index([primaryPhone])
  @@index([ownerName])
  @@index([project])
}

// =====================================================
// HR RECRUITMENT MODULE
