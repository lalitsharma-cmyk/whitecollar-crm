// White Collar Realty CRM — Database schema
// Dev: SQLite (file-based, no setup). Prod: switch provider to "postgresql".

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// USERS, ROLES, TEAMS, AUTH
// =====================================================

enum Role {
  ADMIN
  MANAGER
  AGENT
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String
  passwordHash  String
  role          Role       @default(AGENT)
  team          String?    // "Dubai" / "India" / "HQ"
  phone         String?
  // Acefone agent ID — required for click-to-call (Acefone rings this number first,
  // then dials the lead once the agent picks up). Configure in /team page.
  acefoneAgentId String?
  // Company-assigned WhatsApp Business number for this agent (e.g. "+918XXXXXXX").
  // Used for: (1) outbound WA links open with this number visible to client,
  // (2) when Meta Cloud API is configured, the CRM can poll messages for this
  // number's wa_id and auto-log conversations as Activity rows.
  companyWhatsAppNumber String?
  // Profile photo — stored as base64 dataURL (kept small, no S3 needed for ~10 users).
  // Empty string ("" or null) → fall back to initials avatar.
  photoUrl              String?
  // Reporting line — Managers see leads owned by their direct reports.
  // Self-ref FK. Set in /team page (admin only).
  managerId     String?
  manager       User?      @relation("Reports", fields: [managerId], references: [id])
  reports       User[]     @relation("Reports")
  avatarColor   String?    // tailwind class e.g. "bg-indigo-500"
  active        Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // ── Gamification (Phase 2 of CRM master spec) ──
  // Cumulative XP earned across all actions (calls, conversions, bookings).
  // Level derived from XP via tiers in src/lib/gamification.ts. Streaks track
  // consecutive days the agent met their minimum activity threshold.
  xp                Int       @default(0)
  dailyStreak       Int       @default(0)
  followupStreak    Int       @default(0)
  coldCallStreak    Int       @default(0)
  // Last day (YYYY-MM-DD IST) the streak was incremented — used to detect
  // gaps so the streak resets after a missed day.
  lastStreakDay     String?
  // Comma-separated badge IDs earned. Defined in src/lib/gamification.ts.
  // Cheap-to-query string instead of a join table since badges are append-only.
  badges            String    @default("")

  // ── Agent profile (spec §9.13) ──
  // Comma-separated specialization tags from a fixed vocab. Examples:
  // "Dubai investor", "Gurgaon luxury", "Villa closer", "Commercial", "NRI",
  // "First-time buyer", "Negotiation support". NULL = no specialization yet.
  // Used by lead-routing hints + manager triage.
  specializations   String?
  // Per-agent daily call target. Surfaced in DailyMissionBoard so the agent
  // knows their personal goal for the day. Editable by ADMIN/MANAGER on /team.
  dailyCallTarget   Int       @default(30)

  ownedLeads    Lead[]     @relation("LeadOwner")
  assignments   Assignment[]
  activities    Activity[]
  callLogs      CallLog[]
  notes         Note[]
  auditLogs     AuditLog[]
  notifications Notification[]
  vaultEntries  VaultEntry[]
}

// =====================================================
// LEAD SOURCES, STATUSES
// =====================================================

enum LeadSource {
  WEBSITE
  WHATSAPP
  CSV_IMPORT
  EVENT
  REFERRAL
  INBOUND_CALL
  FACEBOOK_ADS
  GOOGLE_ADS
  PORTAL_99ACRES
  PORTAL_MAGICBRICKS
  PORTAL_HOUSING
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  SITE_VISIT
  NEGOTIATION
  BOOKING_DONE
  WON
  LOST
}

enum AIScore {
  HOT
  WARM
  COLD
}

// Qualification depth — matches Lalit's Dubai-sheet workflow
enum Potential {
  HIGH
  MEDIUM
  LOW
  UNKNOWN
}

enum FundReadiness {
  CASH_READY
  BANK_APPROVED
  FINANCING_NEEDED
  NOT_DISCUSSED
}

enum MoodStatus {
  EXCITED
  INTERESTED
  NEUTRAL
  HESITANT
  COLD
  CONFUSED
  ANGRY
}

enum InvestTimeline {
  IMMEDIATE     // this week
  THIRTY_DAYS
  THREE_MONTHS
  SIX_PLUS_MONTHS
  WINDOW_SHOPPING
  UNKNOWN
}

// BANT qualification verdict — applied AFTER discovery call.
// Budget · Authority · Need · Timeline → Qualifies / Not qualified / Under review.
enum BantStatus {
  UNDER_REVIEW
  QUALIFIES
  NOT_QUALIFIED
}

// Client's earning source — drives messaging tone + EMI eligibility.
enum Profession {
  JOB
  SELF_EMPLOYED
  BUSINESS_OWNER
  INVESTOR
  RETIRED
  STUDENT
  OTHER
}

// =====================================================
// LEAD — the core entity
// =====================================================

model Lead {
  id              String      @id @default(cuid())
  // contact info
  name            String
  // Second person on the same row — e.g. MIS cell "Soumya, Ayush Gupta" with two
  // phone numbers means family/joint buyer. Both belong to ONE lead (joint inquiry),
  // second name lives here, second phone in altPhone. Lead detail shows both.
  altName         String?
  phone           String?
  // Second number. Many MIS sheets put "+919146449146, 7779990838" into one cell —
  // the importer now splits on `,`/`;`/`/`/newline and stores the extra number here.
  // Lead detail renders separate Call + WhatsApp buttons for it.
  altPhone        String?
  email           String?
  company         String?     // where the client works — matters for HNI profiling
  city            String?
  country         String?
  address         String?     // client's physical address (residence)
  // funnel
  source          LeadSource  @default(WEBSITE)
  sourceDetail    String?     // "marina-may-26" campaign code
  status          LeadStatus  @default(NEW)        // = Stage (funnel position)
  currentStatus   String?     // = Status (current state: "Not reached", "Callback today", etc.)
  // requirements
  budgetMin       Float?      // AED for Dubai team
  budgetMax       Float?
  budgetCurrency  String      @default("AED")
  configuration   String?     // "2BHK" / "Penthouse" / "Plot"
  notesShort      String?     // one-liner requirement (legacy)
  remarks         String?     // long remarks (matches sheet's Remarks column)
  tags            String?     // comma-separated for SQLite ("NRI,Investor")
  categorization  String?     // NRI / Resident / Investor / End-user
  language        String?     // "English,Hindi"
  // DEPTH FIELDS (from Dubai sheet — Lalit's priority)
  whoIsClient     String?     // FULL client situation, not keywords
  whenCanInvest   InvestTimeline?
  potential       Potential?
  fundReadiness   FundReadiness?
  moodStatus      MoodStatus?
  // BANT verdict — set after qualification call. Drives the "Qualifies/Not qualified" chip.
  bantStatus      BantStatus  @default(UNDER_REVIEW)
  bantReason      String?     // optional one-liner explaining the verdict
  // Profile depth
  profession      Profession?
  linkedInUrl     String?     // full https://linkedin.com/in/... URL
  // Purchase history — captured at intake for cold data or filled after qualification
  alreadyBought   String?     // comma-separated project names client already owns
  alreadyBoughtBy String?     // who they bought it through (broker name or "direct from Emaar")
  detailShared    String?     // what brochures / details we've sent
  photoUrls       String?     // JSON-stringified URLs of uploaded photos
  // scheduling
  meetingDate     DateTime?   // upcoming/last meeting
  siteVisitDate   DateTime?   // upcoming/last site visit
  followupDate    DateTime?   // next follow-up commitment
  todoNext        String?     // free-text "To Do" — what's the next action
  // AI
  aiScore         AIScore?
  aiScoreValue    Int?        // 0-100
  aiSummary       String?     // long-form auto summary
  aiNextAction    String?     // recommended next step
  aiUpdatedAt     DateTime?
  // ownership
  ownerId         String?
  owner           User?       @relation("LeadOwner", fields: [ownerId], references: [id])
  forwardedTeam   String?     // "Dubai" / "India" — for assignment
  assignedAt      DateTime?   // when ownerId was last set — for 15-min SLA
  // SLA reconciler
  slaFirstCallBy  DateTime?   // ownerId-set + 15 min — escalate if no call by then
  slaEscalated    Boolean     @default(false)  // already notified admin
  // Manager intervention
  needsManagerReview Boolean  @default(false)  // auto-flagged when manager push could help
  managerReviewReason String?                  // why flagged (e.g. "3 not-picked attempts")
  flaggedAt       DateTime?
  // Cold-call bucket — separates outbound cold prospects from real warm leads.
  // Lead lands here when: BANT=NOT_QUALIFIED, OR no contact in 30+ days,
  // OR manager toggles it explicitly. Hides from main /leads list by default.
  isColdCall      Boolean     @default(false)
  coldCallReason  String?
  // dedupe
  fingerprint     String?     @unique  // phone||email hash for dedupe
  duplicateCount  Int         @default(0)  // times this client has re-contacted us
  lastDuplicateAt DateTime?
  // Set when the per-lead callback reminder (~10 min before Lead.followupDate) has
  // already fired — prevents the 5-min pre-meeting cron from re-notifying. Cleared
  // when followupDate is edited (handled by the inline-update endpoint).
  followupReminderSentAt DateTime?

  // ── Rejection / Lost-lead capture ──
  // When agent rejects a lead (status → LOST), capture the reason from a
  // fixed dropdown plus optional free-text. Used in /reports/sla and the
  // Pipeline funnel-leakage analysis to understand WHY deals die.
  // rejectionReason one of: FUND_ISSUE / WAR_FEAR / LOW_BUDGET /
  //   LOOK_AFTER_2_YEARS / WAITING_FOR_PROPERTY_SALE / OTHER
  rejectionReason String?
  rejectionNote   String?   // free-text — required when rejectionReason = OTHER
  rejectedAt      DateTime?
  rejectedById    String?

  // ── EOI / Booking workflow (Phase 6 of CRM master spec §13) ──
  // Stage in the booking funnel — populated once a Lead enters NEGOTIATION
  // or beyond. Pipeline UI shows EOI sub-stages once eoiStage is set.
  eoiStage                  String?     // "EOI_DISCUSSED" / "EOI_COLLECTED" / "KYC_PENDING" / "BOOKING_FORM_SENT" / "BOOKING_FORM_SIGNED" / "PAYMENT_PROOF_RECEIVED" / "DEVELOPER_CONFIRMATION" / "BOOKING_DONE"
  eoiAmount                 Int?        // smallest currency unit (paisa / fils)
  eoiCurrency               String?     // "AED" / "INR"
  eoiPaymentMethod          String?     // "BANK_TRANSFER" / "CARD" / "CHEQUE" / "CASH"
  eoiCollectedAt            DateTime?
  kycStatus                 String?     // "PENDING" / "DOCS_RECEIVED" / "VERIFIED" / "REJECTED"
  kycReceivedAt             DateTime?
  bookingFormStatus         String?     // "NOT_SENT" / "SENT" / "SIGNED" / "REJECTED"
  bookingFormSentAt         DateTime?
  bookingFormSignedAt       DateTime?
  paymentProofStatus        String?     // "PENDING" / "RECEIVED" / "VERIFIED"
  paymentProofReceivedAt    DateTime?
  developerConfirmationStatus String?   // "PENDING" / "CONFIRMED"
  developerConfirmedAt      DateTime?
  bookingDoneAt             DateTime?
  // Commission (post-booking).
  commissionAmount          Int?        // smallest currency unit
  commissionCurrency        String?
  commissionStatus          String?     // "PENDING" / "INVOICED" / "RECEIVED"
  commissionReceivedAt      DateTime?
  // Free-text note about discounts / waivers discussed during EOI.
  eoiNotes                  String?
  // Requires manager / admin sign-off before moving forward.
  eoiApprovalRequired       Boolean     @default(false)
  eoiApprovedById           String?
  eoiApprovedAt             DateTime?

  // timestamps
  lastTouchedAt   DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // relations
  interestedUnits LeadProperty[]
  discussed       LeadProject[]
  activities      Activity[]
  callLogs        CallLog[]
  notes           Note[]
  assignments     Assignment[]
  waMessages      WhatsAppMessage[]

  @@index([status])
  @@index([source])
  @@index([ownerId])
  @@index([createdAt])
  @@index([eoiStage])
}

// =====================================================
// VAULT — Private agent journal + mood + wins (Phase 3 of CRM master spec §10)
// PRIVACY: entries are visible ONLY to the owning user. Admin sees aggregate
// mood/stress counts via a dedicated query that strips text. Never expose
// `content` to non-owners in any API route or UI.
// =====================================================
model VaultEntry {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Type of entry — separate sections in the UI:
  //   JOURNAL   — daily reflection / general thoughts
  //   VENT      — frustration / blow-off (can auto-expire if expiresAt set)
  //   WIN       — celebration / closing / good moment
  //   LESSON    — insight from a deal / mistake
  //   GRATITUDE — what they're grateful for today
  kind       String
  // Optional mood tag — one of:
  //   "GREAT" | "OK" | "STRESSED" | "OVERWHELMED" | "ANGRY" | "SAD"
  mood       String?
  // Free text. NEVER expose to anyone but the owner.
  content    String
  // Optional comma-separated tags (e.g. "client,negotiation,Mehak")
  tags       String?
  // Optional self-destruct for vents (NULL = persists forever).
  expiresAt  DateTime?
  // AI reflection generated for this entry (cached so the UI doesn't re-prompt).
  aiReflection String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, kind])
}

// =====================================================
// PROPERTIES — Project → Unit → Pricing
// =====================================================

enum ProjectStatus {
  OFF_PLAN
  UNDER_CONSTRUCTION
  READY
  SOLD_OUT
}

model Project {
  id            String         @id @default(cuid())
  slug          String?        @unique  // stable key for auto-sync from marketing site
  name          String
  developer     String?
  city          String
  area          String?        // "Dubai Marina" / "Sector 42"
  country       String         @default("UAE")
  status        ProjectStatus  @default(OFF_PLAN)
  handoverDate  DateTime?
  description   String?
  brochureUrl   String?
  imageUrl      String?        // hero image scraped from marketing site
  heroColor     String?        // "from-[#0b1a33] to-[#c9a24b]" tailwind gradient
  rera          String?
  category      String?        // "residential" | "commercial"
  source        String?        // "manual" | "wcr-website" — provenance
  syncedAt      DateTime?      // last time auto-sync touched this row
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  units         Unit[]
  discussedBy   LeadProject[]

  @@index([city])
  @@index([status])
}

// Projects DISCUSSED with a lead (different from interestedUnits which pins specific units)
enum LeadProjectStatus {
  DISCUSSED       // mentioned/sent brochure
  SHORTLISTED     // serious interest
  SITE_VISITED
  RULED_OUT
}

model LeadProject {
  id        String            @id @default(cuid())
  leadId    String
  projectId String
  status    LeadProjectStatus @default(DISCUSSED)
  notes     String?
  discussedAt DateTime        @default(now())
  lead      Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@unique([leadId, projectId])
  @@index([leadId])
  @@index([projectId])
}

enum UnitStatus {
  AVAILABLE
  HOLD
  BOOKED
  SOLD
}

model Unit {
  id              String      @id @default(cuid())
  projectId       String
  project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code            String      // "T-B-1804" tower-block-flat
  configuration   String      // "2BHK" / "Studio" / "PH"
  carpetArea      Float?      // sqft
  builtUpArea     Float?
  floor           Int?
  view            String?
  priceBase       Float
  priceFinal      Float?
  status          UnitStatus  @default(AVAILABLE)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  interestedBy    LeadProperty[]

  @@unique([projectId, code])
  @@index([status])
}

enum LeadInterestType {
  PRIMARY
  COMPARE
  RULED_OUT
}

model LeadProperty {
  id        String           @id @default(cuid())
  leadId    String
  unitId    String
  type      LeadInterestType @default(PRIMARY)
  notes     String?
  createdAt DateTime         @default(now())

  lead      Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  unit      Unit             @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([leadId, unitId])
}

// =====================================================
// ACTIVITIES, CALLS, NOTES, WA MESSAGES
// =====================================================

enum ActivityType {
  CALL
  WHATSAPP
  EMAIL
  SITE_VISIT
  OFFICE_MEETING
  VIRTUAL_MEETING
  HOME_VISIT          // India team — agent visits client at home
  EXPO_MEETING        // Dubai team — meets prospect at a developer Expo (held in IN cities)
  COLD_TO_LEAD        // Logged when agent promotes a cold-data row to a real lead
  MEETING             // legacy — kept for backwards compatibility
  TASK
  NOTE
  STATUS_CHANGE
  ASSIGNMENT
  LEAD_CREATED
  BROCHURE_SENT
  PROJECT_DISCUSSED
  REMINDER_FIRED
}

enum ActivityStatus {
  PLANNED
  DONE
  OVERDUE
  CANCELLED
}

model Activity {
  id          String         @id @default(cuid())
  leadId      String
  lead        Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?          @relation(fields: [userId], references: [id])
  type        ActivityType
  status      ActivityStatus @default(PLANNED)
  title       String
  description String?
  scheduledAt DateTime?
  completedAt DateTime?
  // ── Visit/meeting attendance + live-tracking (SITE_VISIT, OFFICE_MEETING, VIRTUAL_MEETING) ──
  /// Who actually attended (may differ from `userId`/owner — e.g. agent sent a colleague)
  attendedByUserId   String?
  /// Comma-separated user ids of co-attendees (joint visits)
  additionalAttendees String?
  /// Number of times this activity was rescheduled (incremented when scheduledAt changes pre-completion)
  rescheduledCount   Int       @default(0)
  /// True if nobody showed up (used in SLA report)
  isNoShow           Boolean   @default(false)
  /// Live-tracking — captured when agent taps "Start Site Visit"
  startedAt          DateTime?
  startedLat         Float?
  startedLng         Float?
  endedAt            DateTime?
  endedLat           Float?
  endedLng           Float?
  /// JSON-stringified [{ts, lat, lng}, …] — polled every 60s between Start and End
  locationTrack      String?
  /// When the 30-min-before pre-meeting reminder fired (dedupe for the 5-min cron)
  reminderSentAt     DateTime?
  // ── Expo meeting fields (Dubai team — meets prospects at developer expos in IN cities) ──
  expoCity            String?    // "Gurgaon", "Delhi", "Mumbai", "Bangalore"
  expoHotel           String?    // venue name
  expoDeveloper       String?    // which developer hosted (Emaar / Sobha / DLF…)
  expoDeveloperContact String?   // developer's salesperson name we coordinated with
  expoAgentAttended   Boolean   @default(false) // did our agent travel + attend in person?
  // ── Dubai site-visit fields (we don't have an office in Dubai, so coordination matters) ──
  dubaiDeveloperSalesperson String?
  cabScheduled       Boolean    @default(false)
  decisionInOffice   Boolean    @default(false) // did client decide on the spot at developer office
  // ── India travel reimbursement (auto-calculated from distanceKm * per-km rate) ──
  distanceKm           Float?
  reimbursementAmount  Float?    // INR, computed at log time using Setting.travelPerKmInr
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([leadId])
  @@index([scheduledAt])
  @@index([status])
  @@index([type, completedAt])
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallOutcome {
  CONNECTED
  NOT_PICKED
  CALLBACK
  WRONG_NUMBER
  BUSY
  SWITCHED_OFF
  INTERESTED
  NOT_INTERESTED
}

model CallLog {
  id           String         @id @default(cuid())
  leadId       String?
  lead         Lead?          @relation(fields: [leadId], references: [id])
  userId       String
  user         User           @relation(fields: [userId], references: [id])
  direction    CallDirection  @default(OUTBOUND)
  phoneNumber  String
  durationSec  Int?
  outcome      CallOutcome
  notes        String?
  // When a CallLog was created from a MIS-import remark cell, the actual person
  // who made the call is in the remark text (e.g. "Nitisha: on 16 May..."). The
  // importer-as-user (often the admin) is wrong for display. Set this column
  // to the parsed agent name so the call history shows WHO actually called
  // rather than who imported the sheet.
  // Null when an agent logs a call live in the UI (user.name is correct then).
  attributedAgentName String?
  // IVR-ready fields
  ivrProvider  String?        // "exotel" / "knowlarity" / "myoperator" / null for manual
  ivrCallId    String?        @unique
  recordingUrl String?
  startedAt    DateTime       @default(now())
  endedAt      DateTime?
  createdAt    DateTime       @default(now())

  @@index([leadId])
  @@index([userId])
  @@index([startedAt])
}

model Note {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([leadId])
}

enum WAMessageDirection {
  INBOUND
  OUTBOUND
}

model WhatsAppMessage {
  id          String              @id @default(cuid())
  leadId      String?
  lead        Lead?               @relation(fields: [leadId], references: [id])
  phoneNumber String
  direction   WAMessageDirection
  body        String
  templateId  String?
  providerMsgId String?           @unique
  receivedAt  DateTime            @default(now())

  @@index([phoneNumber])
  @@index([leadId])
}

// =====================================================
// ASSIGNMENT HISTORY (for distribution audit)
// =====================================================

model Assignment {
  id         String   @id @default(cuid())
  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  reason     String?  // "round-robin" / "manual" / "rule:dubai"
  assignedAt DateTime @default(now())
  @@index([leadId])
  @@index([userId])
}

// =====================================================
// AUDIT LOG
// =====================================================

// ──────────────────────────────────────────────────────────
// DAILY MOOD — end-of-day check-in (optional, max one per agent per day)
// Drives: team-mood widget for admin + culture trend over time.
// ──────────────────────────────────────────────────────────
enum Mood {
  FRUSTRATING   // 😣
  NOT_GREAT     // 🙁
  MIXED         // 😐
  LOOKS_GOOD    // 🙂
  AWESOME       // 😍
}

model DailyMood {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date     // truncated to day
  mood      Mood
  comment   String?               // optional follow-up answer
  createdAt DateTime @default(now())
  @@unique([userId, date])
  @@index([date])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String   // "lead.create", "lead.assign", "user.invite"
  entity    String   // "Lead" / "User" / ...
  entityId  String?
  meta      String?  // JSON-stringified extras (SQLite has no JSON type)
  createdAt DateTime @default(now())
  @@index([entity, entityId])
  @@index([createdAt])
}

// =====================================================
// INTAKE API KEYS (for website + WhatsApp webhooks)
// =====================================================

model IntakeKey {
  id        String     @id @default(cuid())
  label     String
  key       String     @unique
  source    LeadSource
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  lastUsed  DateTime?
}

// =====================================================
// SETTINGS (singleton key-value)
// =====================================================

model Setting {
  key   String @id
  value String
}

// ──────────────────────────────────────────────────────────
// MESSAGE TEMPLATES — WhatsApp + Email library with placeholders.
// Placeholders auto-substituted at send time:
//   {{name}}      → lead first name
//   {{fullname}}  → lead full name
//   {{agent}}     → sender's first name
//   {{project}}   → first interested project name (if any)
//   {{budget}}    → formatted budget min (e.g. "AED 2.5M")
//   {{phone}}     → lead phone (E.164)
// Trigger lets the picker auto-suggest the right template for the stage.
// ──────────────────────────────────────────────────────────
enum TemplateKind {
  WHATSAPP
  EMAIL
}

enum TemplateTrigger {
  FIRST_QUERY        // brand-new lead, first ever contact
  AFTER_CALL         // just had a call, sending follow-up
  AFTER_NOT_PICKED   // 1+ missed-call attempts, re-engage
  SCHEDULE_VISIT     // book a site visit
  POST_VISIT         // after the site visit
  NEGOTIATION        // discussing price / payment plan
  REENGAGE_COLD      // dormant for weeks, fresh nudge
  GENERIC            // catch-all
}

model Template {
  id          String          @id @default(cuid())
  kind        TemplateKind
  name        String
  trigger     TemplateTrigger @default(GENERIC)
  subject     String?         // only used for EMAIL
  body        String          @db.Text
  active      Boolean         @default(true)
  createdById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([kind, active])
  @@index([trigger])
}

// ──────────────────────────────────────────────────────────
// SAVED FILTERS — named views on /leads. Store the URL query string
// (e.g. "ai=HOT&team=Dubai") and re-apply with one click. Shared filters
// visible to whole team; private ones only to the creator.
// ──────────────────────────────────────────────────────────
model SavedFilter {
  id          String   @id @default(cuid())
  name        String
  queryString String   @db.Text   // e.g. "ai=HOT&team=Dubai&sort=touched_asc"
  icon        String?              // emoji, e.g. "🔥"
  createdById String?              // null = system seed (visible to all, only admin can delete)
  isShared    Boolean  @default(true) // visible to whole team if true
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdById])
  @@index([isShared, sortOrder])
}

// ──────────────────────────────────────────────────────────
// WORKFLOW ENGINE — Zoho-style rules + drip campaigns.
//
// A Workflow has one TRIGGER + an ordered list of ACTIONS. When the trigger
// fires for a lead, the engine queues every action (some immediate, some
// delayed). A delayed action waits until its `runAt` time, then a cron sweep
// dispatches it. WorkflowRun rows track which workflow×lead pairs have already
// fired (idempotency) plus pending vs done state for delayed actions.
// ──────────────────────────────────────────────────────────
enum WorkflowTrigger {
  LEAD_CREATED         // new lead intake
  STATUS_CHANGED       // lead.status moved
  BANT_CHANGED         // BANT verdict set (Qualifies / Not qualified)
  STAGE_TIME           // X minutes in a specific stage
  NO_CONTACT_DAYS      // No call/WA/email in N days
  NOT_PICKED_STREAK    // N consecutive NOT_PICKED outcomes
  COLD_PROMOTED        // Cold-data → Lead promotion
}

enum WorkflowActionType {
  SEND_WA              // Send WhatsApp template (config.templateId)
  SEND_EMAIL           // Send email template (config.templateId)
  CREATE_TASK          // Create planned Activity for the owner (config: title, dueInMinutes)
  NOTIFY_ADMIN         // In-app + email notification to Admin/Manager
  NOTIFY_OWNER         // In-app notification to lead's owner
  SET_FIELD            // Set Lead field (config: field, value)
  ADD_TAG              // Append to Lead.tags (config: tag)
}

enum WorkflowRunStatus {
  PENDING              // queued, waiting for runAt
  RUNNING
  DONE
  FAILED
  SKIPPED              // condition no longer met when dispatcher ran
}

model Workflow {
  id            String           @id @default(cuid())
  name          String
  description   String?
  trigger       WorkflowTrigger
  triggerConfig String?          @db.Text  // JSON — { status?: "NEW", days?: 7, etc. }
  /// "Only fire if lead matches this query string" — e.g. "team=Dubai&ai=HOT"
  /// Empty = applies to every lead.
  filterQuery   String?
  active        Boolean          @default(true)
  createdById   String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  actions       WorkflowAction[]
  runs          WorkflowRun[]

  @@index([trigger, active])
}

model WorkflowAction {
  id           String             @id @default(cuid())
  workflowId   String
  workflow     Workflow           @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  sequenceOrder Int               @default(0)
  type         WorkflowActionType
  config       String             @db.Text  // JSON
  /// 0 = run immediately. >0 = schedule for runAt = trigger time + delayMinutes.
  delayMinutes Int                @default(0)

  runs         WorkflowRun[]

  @@index([workflowId, sequenceOrder])
}

model WorkflowRun {
  id           String             @id @default(cuid())
  workflowId   String
  workflow     Workflow           @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  actionId     String?            // null = the "trigger fired" master row (one per workflow+lead+triggerEvent)
  action       WorkflowAction?    @relation(fields: [actionId], references: [id], onDelete: Cascade)
  leadId       String
  status       WorkflowRunStatus  @default(PENDING)
  runAt        DateTime           // when to dispatch this action (now() for immediate, future for delayed)
  startedAt    DateTime?
  finishedAt   DateTime?
  error        String?            @db.Text
  /// Idempotency dedupe key — same trigger+lead+actionId should never fire twice.
  /// Built like "<workflowId>:<leadId>:<actionId>:<eventTs>" for delays, or "<workflowId>:<leadId>" for once-only.
  dedupeKey    String             @unique
  createdAt    DateTime           @default(now())

  @@index([status, runAt])
  @@index([leadId])
}

// =====================================================
// NOTIFICATIONS — in-app bell + per-user inbox
// =====================================================

enum NotifKind {
  LEAD_ASSIGNED       // your lead arrived
  LEAD_DUPLICATE      // an existing lead re-contacted
  CALL_SLA_BREACH     // 15 min passed, no call logged
  AUTO_ASSIGN_FIRED   // 5 min, admin didn't assign — auto-assigned
  REMINDER            // generic follow-up reminder
  SYSTEM              // info / settings change
}

enum NotifSeverity {
  INFO
  WARNING
  CRITICAL
}

model Notification {
  id        String        @id @default(cuid())
  userId    String        // recipient
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      NotifKind
  severity  NotifSeverity @default(INFO)
  title     String
  body      String?
  linkUrl   String?       // where clicking it takes you (e.g. /leads/abc)
  leadId    String?       // optional related lead
  readAt    DateTime?     // null = unread
  // When set + in the future, the notification is hidden from the inbox until that time.
  // Cleared automatically by simply letting the timestamp pass (no cron needed — queries
  // filter `snoozedUntil > now`).
  snoozedUntil DateTime?
  createdAt DateTime      @default(now())
  @@index([userId, readAt])
  @@index([createdAt])
}

// =====================================================
// WEB PUSH — browser push notifications to phone / desktop
// =====================================================

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   // who is subscribed
  endpoint  String   @unique  // browser-issued URL
  p256dh    String   // encryption pubkey
  authKey   String   // auth secret
  userAgent String?  // for debugging which device
  createdAt DateTime @default(now())
  @@index([userId])
}

// =====================================================
// CUSTOM FIELDS — admin can add new fields per entity, no code
// =====================================================

enum CustomFieldKind {
  TEXT
  TEXTAREA
  NUMBER
  DATE
  SELECT
  CHECKBOX
}

enum CustomFieldEntity {
  LEAD
  PROJECT
}

model CustomField {
  id         String            @id @default(cuid())
  entity     CustomFieldEntity
  key        String
  label      String
  kind       CustomFieldKind   @default(TEXT)
  options    String?
  required   Boolean           @default(false)
  position   Int               @default(0)
  active     Boolean           @default(true)
  createdAt  DateTime          @default(now())
  values     CustomFieldValue[]
  @@unique([entity, key])
}

model CustomFieldValue {
  id        String      @id @default(cuid())
  fieldId   String
  field     CustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  entityId  String
  value     String
  @@unique([fieldId, entityId])
  @@index([entityId])
}

// =====================================================
// AGENT TARGETS — daily call/meeting/booking targets
// =====================================================

enum TargetMetric {
  CALLS             // total dial-outs
  CONNECTED_CALLS
  SITE_VISITS
  MEETINGS          // legacy — kept for back-compat
  VIRTUAL_MEETINGS
  F2F_MEETINGS      // office + site combined (in-person)
  FRESH_CLIENTS     // new leads created (or cold→lead promotions)
  DEALS_CLOSED      // count of WON
  REVENUE_AED       // sum of won deals in AED
  REVENUE_INR
  BOOKINGS
}

model Target {
  id        String       @id @default(cuid())
  userId    String?
  team      String?
  metric    TargetMetric
  value     Float
  period    String       @default("DAILY")
  startDate DateTime     @default(now())
  endDate   DateTime?
  @@index([userId, metric, period])
  @@index([team, metric, period])
}

// =====================================================
// AGENT ATTENDANCE — login/logout tracking
// =====================================================

model AttendanceLog {
  id        String   @id @default(cuid())
  userId    String
  loginAt   DateTime @default(now())
  logoutAt  DateTime?
  ip        String?
  userAgent String?
  @@index([userId, loginAt])
}

// Daily attendance — drives round-robin (only PRESENT/LATE agents get leads).
// One row per agent per day. Auto-set on first login (PRESENT if before 10:30am,
// LATE after), can be admin-overridden.
enum AttendanceStatus {
  PRESENT     // logged in by 10:30am
  LATE        // logged in 10:30am-7pm
  ABSENT      // never logged in (or admin marked)
  ON_LEAVE    // admin marked — planned leave
}

model Attendance {
  id        String           @id @default(cuid())
  userId    String
  date      DateTime         @db.Date
  status    AttendanceStatus @default(PRESENT)
  markedAt  DateTime         @default(now())
  markedBy  String?          // null = self-mark / auto, else admin userId
  notes     String?
  @@unique([userId, date])
  @@index([date])
}
