// White Collar Realty CRM — Database schema
// Dev: SQLite (file-based, no setup). Prod: switch provider to "postgresql".

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// USERS, ROLES, TEAMS, AUTH
// =====================================================

enum Role {
  ADMIN
  MANAGER
  AGENT
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String
  passwordHash  String
  role          Role       @default(AGENT)
  team          String?    // "Dubai" / "India" / "HQ"
  phone         String?
  // Acefone agent ID — required for click-to-call (Acefone rings this number first,
  // then dials the lead once the agent picks up). Configure in /team page.
  acefoneAgentId String?
  // Company-assigned WhatsApp Business number for this agent (e.g. "+918XXXXXXX").
  // Used for: (1) outbound WA links open with this number visible to client,
  // (2) when Meta Cloud API is configured, the CRM can poll messages for this
  // number's wa_id and auto-log conversations as Activity rows.
  companyWhatsAppNumber String?
  // Profile photo — stored as base64 dataURL (kept small, no S3 needed for ~10 users).
  // Empty string ("" or null) → fall back to initials avatar.
  photoUrl              String?
  // Reporting line — Managers see leads owned by their direct reports.
  // Self-ref FK. Set in /team page (admin only).
  managerId     String?
  manager       User?      @relation("Reports", fields: [managerId], references: [id])
  reports       User[]     @relation("Reports")
  avatarColor   String?    // tailwind class e.g. "bg-indigo-500"
  active        Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  ownedLeads    Lead[]     @relation("LeadOwner")
  assignments   Assignment[]
  activities    Activity[]
  callLogs      CallLog[]
  notes         Note[]
  auditLogs     AuditLog[]
  notifications Notification[]
}

// =====================================================
// LEAD SOURCES, STATUSES
// =====================================================

enum LeadSource {
  WEBSITE
  WHATSAPP
  CSV_IMPORT
  EVENT
  REFERRAL
  INBOUND_CALL
  FACEBOOK_ADS
  GOOGLE_ADS
  PORTAL_99ACRES
  PORTAL_MAGICBRICKS
  PORTAL_HOUSING
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  SITE_VISIT
  NEGOTIATION
  BOOKING_DONE
  WON
  LOST
}

enum AIScore {
  HOT
  WARM
  COLD
}

// Qualification depth — matches Lalit's Dubai-sheet workflow
enum Potential {
  HIGH
  MEDIUM
  LOW
  UNKNOWN
}

enum FundReadiness {
  CASH_READY
  BANK_APPROVED
  FINANCING_NEEDED
  NOT_DISCUSSED
}

enum MoodStatus {
  EXCITED
  INTERESTED
  NEUTRAL
  HESITANT
  COLD
  CONFUSED
  ANGRY
}

enum InvestTimeline {
  IMMEDIATE     // this week
  THIRTY_DAYS
  THREE_MONTHS
  SIX_PLUS_MONTHS
  WINDOW_SHOPPING
  UNKNOWN
}

// BANT qualification verdict — applied AFTER discovery call.
// Budget · Authority · Need · Timeline → Qualifies / Not qualified / Under review.
enum BantStatus {
  UNDER_REVIEW
  QUALIFIES
  NOT_QUALIFIED
}

// Client's earning source — drives messaging tone + EMI eligibility.
enum Profession {
  JOB
  SELF_EMPLOYED
  BUSINESS_OWNER
  INVESTOR
  RETIRED
  STUDENT
  OTHER
}

// =====================================================
// LEAD — the core entity
// =====================================================

model Lead {
  id              String      @id @default(cuid())
  // contact info
  name            String
  phone           String?
  email           String?
  company         String?     // where the client works — matters for HNI profiling
  city            String?
  country         String?
  address         String?     // client's physical address (residence)
  // funnel
  source          LeadSource  @default(WEBSITE)
  sourceDetail    String?     // "marina-may-26" campaign code
  status          LeadStatus  @default(NEW)        // = Stage (funnel position)
  currentStatus   String?     // = Status (current state: "Not reached", "Callback today", etc.)
  // requirements
  budgetMin       Float?      // AED for Dubai team
  budgetMax       Float?
  budgetCurrency  String      @default("AED")
  configuration   String?     // "2BHK" / "Penthouse" / "Plot"
  notesShort      String?     // one-liner requirement (legacy)
  remarks         String?     // long remarks (matches sheet's Remarks column)
  tags            String?     // comma-separated for SQLite ("NRI,Investor")
  categorization  String?     // NRI / Resident / Investor / End-user
  language        String?     // "English,Hindi"
  // DEPTH FIELDS (from Dubai sheet — Lalit's priority)
  whoIsClient     String?     // FULL client situation, not keywords
  whenCanInvest   InvestTimeline?
  potential       Potential?
  fundReadiness   FundReadiness?
  moodStatus      MoodStatus?
  // BANT verdict — set after qualification call. Drives the "Qualifies/Not qualified" chip.
  bantStatus      BantStatus  @default(UNDER_REVIEW)
  bantReason      String?     // optional one-liner explaining the verdict
  // Profile depth
  profession      Profession?
  linkedInUrl     String?     // full https://linkedin.com/in/... URL
  // Purchase history — captured at intake for cold data or filled after qualification
  alreadyBought   String?     // comma-separated project names client already owns
  alreadyBoughtBy String?     // who they bought it through (broker name or "direct from Emaar")
  detailShared    String?     // what brochures / details we've sent
  photoUrls       String?     // JSON-stringified URLs of uploaded photos
  // scheduling
  meetingDate     DateTime?   // upcoming/last meeting
  siteVisitDate   DateTime?   // upcoming/last site visit
  followupDate    DateTime?   // next follow-up commitment
  todoNext        String?     // free-text "To Do" — what's the next action
  // AI
  aiScore         AIScore?
  aiScoreValue    Int?        // 0-100
  aiSummary       String?     // long-form auto summary
  aiNextAction    String?     // recommended next step
  aiUpdatedAt     DateTime?
  // ownership
  ownerId         String?
  owner           User?       @relation("LeadOwner", fields: [ownerId], references: [id])
  forwardedTeam   String?     // "Dubai" / "India" — for assignment
  assignedAt      DateTime?   // when ownerId was last set — for 15-min SLA
  // SLA reconciler
  slaFirstCallBy  DateTime?   // ownerId-set + 15 min — escalate if no call by then
  slaEscalated    Boolean     @default(false)  // already notified admin
  // Manager intervention
  needsManagerReview Boolean  @default(false)  // auto-flagged when manager push could help
  managerReviewReason String?                  // why flagged (e.g. "3 not-picked attempts")
  flaggedAt       DateTime?
  // Cold-call bucket — separates outbound cold prospects from real warm leads.
  // Lead lands here when: BANT=NOT_QUALIFIED, OR no contact in 30+ days,
  // OR manager toggles it explicitly. Hides from main /leads list by default.
  isColdCall      Boolean     @default(false)
  coldCallReason  String?
  // dedupe
  fingerprint     String?     @unique  // phone||email hash for dedupe
  duplicateCount  Int         @default(0)  // times this client has re-contacted us
  lastDuplicateAt DateTime?
  // timestamps
  lastTouchedAt   DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // relations
  interestedUnits LeadProperty[]
  discussed       LeadProject[]
  activities      Activity[]
  callLogs        CallLog[]
  notes           Note[]
  assignments     Assignment[]
  waMessages      WhatsAppMessage[]

  @@index([status])
  @@index([source])
  @@index([ownerId])
  @@index([createdAt])
}

// =====================================================
// PROPERTIES — Project → Unit → Pricing
// =====================================================

enum ProjectStatus {
  OFF_PLAN
  UNDER_CONSTRUCTION
  READY
  SOLD_OUT
}

model Project {
  id            String         @id @default(cuid())
  slug          String?        @unique  // stable key for auto-sync from marketing site
  name          String
  developer     String?
  city          String
  area          String?        // "Dubai Marina" / "Sector 42"
  country       String         @default("UAE")
  status        ProjectStatus  @default(OFF_PLAN)
  handoverDate  DateTime?
  description   String?
  brochureUrl   String?
  imageUrl      String?        // hero image scraped from marketing site
  heroColor     String?        // "from-[#0b1a33] to-[#c9a24b]" tailwind gradient
  rera          String?
  category      String?        // "residential" | "commercial"
  source        String?        // "manual" | "wcr-website" — provenance
  syncedAt      DateTime?      // last time auto-sync touched this row
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  units         Unit[]
  discussedBy   LeadProject[]

  @@index([city])
  @@index([status])
}

// Projects DISCUSSED with a lead (different from interestedUnits which pins specific units)
enum LeadProjectStatus {
  DISCUSSED       // mentioned/sent brochure
  SHORTLISTED     // serious interest
  SITE_VISITED
  RULED_OUT
}

model LeadProject {
  id        String            @id @default(cuid())
  leadId    String
  projectId String
  status    LeadProjectStatus @default(DISCUSSED)
  notes     String?
  discussedAt DateTime        @default(now())
  lead      Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@unique([leadId, projectId])
  @@index([leadId])
  @@index([projectId])
}

enum UnitStatus {
  AVAILABLE
  HOLD
  BOOKED
  SOLD
}

model Unit {
  id              String      @id @default(cuid())
  projectId       String
  project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code            String      // "T-B-1804" tower-block-flat
  configuration   String      // "2BHK" / "Studio" / "PH"
  carpetArea      Float?      // sqft
  builtUpArea     Float?
  floor           Int?
  view            String?
  priceBase       Float
  priceFinal      Float?
  status          UnitStatus  @default(AVAILABLE)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  interestedBy    LeadProperty[]

  @@unique([projectId, code])
  @@index([status])
}

enum LeadInterestType {
  PRIMARY
  COMPARE
  RULED_OUT
}

model LeadProperty {
  id        String           @id @default(cuid())
  leadId    String
  unitId    String
  type      LeadInterestType @default(PRIMARY)
  notes     String?
  createdAt DateTime         @default(now())

  lead      Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  unit      Unit             @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([leadId, unitId])
}

// =====================================================
// ACTIVITIES, CALLS, NOTES, WA MESSAGES
// =====================================================

enum ActivityType {
  CALL
  WHATSAPP
  EMAIL
  SITE_VISIT
  OFFICE_MEETING
  VIRTUAL_MEETING
  HOME_VISIT          // India team — agent visits client at home
  EXPO_MEETING        // Dubai team — meets prospect at a developer Expo (held in IN cities)
  COLD_TO_LEAD        // Logged when agent promotes a cold-data row to a real lead
  MEETING             // legacy — kept for backwards compatibility
  TASK
  NOTE
  STATUS_CHANGE
  ASSIGNMENT
  LEAD_CREATED
  BROCHURE_SENT
  PROJECT_DISCUSSED
  REMINDER_FIRED
}

enum ActivityStatus {
  PLANNED
  DONE
  OVERDUE
  CANCELLED
}

model Activity {
  id          String         @id @default(cuid())
  leadId      String
  lead        Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?          @relation(fields: [userId], references: [id])
  type        ActivityType
  status      ActivityStatus @default(PLANNED)
  title       String
  description String?
  scheduledAt DateTime?
  completedAt DateTime?
  // ── Visit/meeting attendance + live-tracking (SITE_VISIT, OFFICE_MEETING, VIRTUAL_MEETING) ──
  /// Who actually attended (may differ from `userId`/owner — e.g. agent sent a colleague)
  attendedByUserId   String?
  /// Comma-separated user ids of co-attendees (joint visits)
  additionalAttendees String?
  /// Number of times this activity was rescheduled (incremented when scheduledAt changes pre-completion)
  rescheduledCount   Int       @default(0)
  /// True if nobody showed up (used in SLA report)
  isNoShow           Boolean   @default(false)
  /// Live-tracking — captured when agent taps "Start Site Visit"
  startedAt          DateTime?
  startedLat         Float?
  startedLng         Float?
  endedAt            DateTime?
  endedLat           Float?
  endedLng           Float?
  /// JSON-stringified [{ts, lat, lng}, …] — polled every 60s between Start and End
  locationTrack      String?
  // ── Expo meeting fields (Dubai team — meets prospects at developer expos in IN cities) ──
  expoCity            String?    // "Gurgaon", "Delhi", "Mumbai", "Bangalore"
  expoHotel           String?    // venue name
  expoDeveloper       String?    // which developer hosted (Emaar / Sobha / DLF…)
  expoDeveloperContact String?   // developer's salesperson name we coordinated with
  expoAgentAttended   Boolean   @default(false) // did our agent travel + attend in person?
  // ── Dubai site-visit fields (we don't have an office in Dubai, so coordination matters) ──
  dubaiDeveloperSalesperson String?
  cabScheduled       Boolean    @default(false)
  decisionInOffice   Boolean    @default(false) // did client decide on the spot at developer office
  // ── India travel reimbursement (auto-calculated from distanceKm * per-km rate) ──
  distanceKm           Float?
  reimbursementAmount  Float?    // INR, computed at log time using Setting.travelPerKmInr
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([leadId])
  @@index([scheduledAt])
  @@index([status])
  @@index([type, completedAt])
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallOutcome {
  CONNECTED
  NOT_PICKED
  CALLBACK
  WRONG_NUMBER
  BUSY
  SWITCHED_OFF
  INTERESTED
  NOT_INTERESTED
}

model CallLog {
  id           String         @id @default(cuid())
  leadId       String?
  lead         Lead?          @relation(fields: [leadId], references: [id])
  userId       String
  user         User           @relation(fields: [userId], references: [id])
  direction    CallDirection  @default(OUTBOUND)
  phoneNumber  String
  durationSec  Int?
  outcome      CallOutcome
  notes        String?
  // IVR-ready fields
  ivrProvider  String?        // "exotel" / "knowlarity" / "myoperator" / null for manual
  ivrCallId    String?        @unique
  recordingUrl String?
  startedAt    DateTime       @default(now())
  endedAt      DateTime?
  createdAt    DateTime       @default(now())

  @@index([leadId])
  @@index([userId])
  @@index([startedAt])
}

model Note {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([leadId])
}

enum WAMessageDirection {
  INBOUND
  OUTBOUND
}

model WhatsAppMessage {
  id          String              @id @default(cuid())
  leadId      String?
  lead        Lead?               @relation(fields: [leadId], references: [id])
  phoneNumber String
  direction   WAMessageDirection
  body        String
  templateId  String?
  providerMsgId String?           @unique
  receivedAt  DateTime            @default(now())

  @@index([phoneNumber])
  @@index([leadId])
}

// =====================================================
// ASSIGNMENT HISTORY (for distribution audit)
// =====================================================

model Assignment {
  id         String   @id @default(cuid())
  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  reason     String?  // "round-robin" / "manual" / "rule:dubai"
  assignedAt DateTime @default(now())
  @@index([leadId])
  @@index([userId])
}

// =====================================================
// AUDIT LOG
// =====================================================

// ──────────────────────────────────────────────────────────
// DAILY MOOD — end-of-day check-in (optional, max one per agent per day)
// Drives: team-mood widget for admin + culture trend over time.
// ──────────────────────────────────────────────────────────
enum Mood {
  FRUSTRATING   // 😣
  NOT_GREAT     // 🙁
  MIXED         // 😐
  LOOKS_GOOD    // 🙂
  AWESOME       // 😍
}

model DailyMood {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date     // truncated to day
  mood      Mood
  comment   String?               // optional follow-up answer
  createdAt DateTime @default(now())
  @@unique([userId, date])
  @@index([date])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String   // "lead.create", "lead.assign", "user.invite"
  entity    String   // "Lead" / "User" / ...
  entityId  String?
  meta      String?  // JSON-stringified extras (SQLite has no JSON type)
  createdAt DateTime @default(now())
  @@index([entity, entityId])
  @@index([createdAt])
}

// =====================================================
// INTAKE API KEYS (for website + WhatsApp webhooks)
// =====================================================

model IntakeKey {
  id        String     @id @default(cuid())
  label     String
  key       String     @unique
  source    LeadSource
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  lastUsed  DateTime?
}

// =====================================================
// SETTINGS (singleton key-value)
// =====================================================

model Setting {
  key   String @id
  value String
}

// ──────────────────────────────────────────────────────────
// MESSAGE TEMPLATES — WhatsApp + Email library with placeholders.
// Placeholders auto-substituted at send time:
//   {{name}}      → lead first name
//   {{fullname}}  → lead full name
//   {{agent}}     → sender's first name
//   {{project}}   → first interested project name (if any)
//   {{budget}}    → formatted budget min (e.g. "AED 2.5M")
//   {{phone}}     → lead phone (E.164)
// Trigger lets the picker auto-suggest the right template for the stage.
// ──────────────────────────────────────────────────────────
enum TemplateKind {
  WHATSAPP
  EMAIL
}

enum TemplateTrigger {
  FIRST_QUERY        // brand-new lead, first ever contact
  AFTER_CALL         // just had a call, sending follow-up
  AFTER_NOT_PICKED   // 1+ missed-call attempts, re-engage
  SCHEDULE_VISIT     // book a site visit
  POST_VISIT         // after the site visit
  NEGOTIATION        // discussing price / payment plan
  REENGAGE_COLD      // dormant for weeks, fresh nudge
  GENERIC            // catch-all
}

model Template {
  id          String          @id @default(cuid())
  kind        TemplateKind
  name        String
  trigger     TemplateTrigger @default(GENERIC)
  subject     String?         // only used for EMAIL
  body        String          @db.Text
  active      Boolean         @default(true)
  createdById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([kind, active])
  @@index([trigger])
}

// ──────────────────────────────────────────────────────────
// SAVED FILTERS — named views on /leads. Store the URL query string
// (e.g. "ai=HOT&team=Dubai") and re-apply with one click. Shared filters
// visible to whole team; private ones only to the creator.
// ──────────────────────────────────────────────────────────
model SavedFilter {
  id          String   @id @default(cuid())
  name        String
  queryString String   @db.Text   // e.g. "ai=HOT&team=Dubai&sort=touched_asc"
  icon        String?              // emoji, e.g. "🔥"
  createdById String?              // null = system seed (visible to all, only admin can delete)
  isShared    Boolean  @default(true) // visible to whole team if true
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdById])
  @@index([isShared, sortOrder])
}

// =====================================================
// NOTIFICATIONS — in-app bell + per-user inbox
// =====================================================

enum NotifKind {
  LEAD_ASSIGNED       // your lead arrived
  LEAD_DUPLICATE      // an existing lead re-contacted
  CALL_SLA_BREACH     // 15 min passed, no call logged
  AUTO_ASSIGN_FIRED   // 5 min, admin didn't assign — auto-assigned
  REMINDER            // generic follow-up reminder
  SYSTEM              // info / settings change
}

enum NotifSeverity {
  INFO
  WARNING
  CRITICAL
}

model Notification {
  id        String        @id @default(cuid())
  userId    String        // recipient
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      NotifKind
  severity  NotifSeverity @default(INFO)
  title     String
  body      String?
  linkUrl   String?       // where clicking it takes you (e.g. /leads/abc)
  leadId    String?       // optional related lead
  readAt    DateTime?     // null = unread
  createdAt DateTime      @default(now())
  @@index([userId, readAt])
  @@index([createdAt])
}

// =====================================================
// WEB PUSH — browser push notifications to phone / desktop
// =====================================================

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   // who is subscribed
  endpoint  String   @unique  // browser-issued URL
  p256dh    String   // encryption pubkey
  authKey   String   // auth secret
  userAgent String?  // for debugging which device
  createdAt DateTime @default(now())
  @@index([userId])
}

// =====================================================
// CUSTOM FIELDS — admin can add new fields per entity, no code
// =====================================================

enum CustomFieldKind {
  TEXT
  TEXTAREA
  NUMBER
  DATE
  SELECT
  CHECKBOX
}

enum CustomFieldEntity {
  LEAD
  PROJECT
}

model CustomField {
  id         String            @id @default(cuid())
  entity     CustomFieldEntity
  key        String
  label      String
  kind       CustomFieldKind   @default(TEXT)
  options    String?
  required   Boolean           @default(false)
  position   Int               @default(0)
  active     Boolean           @default(true)
  createdAt  DateTime          @default(now())
  values     CustomFieldValue[]
  @@unique([entity, key])
}

model CustomFieldValue {
  id        String      @id @default(cuid())
  fieldId   String
  field     CustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  entityId  String
  value     String
  @@unique([fieldId, entityId])
  @@index([entityId])
}

// =====================================================
// AGENT TARGETS — daily call/meeting/booking targets
// =====================================================

enum TargetMetric {
  CALLS             // total dial-outs
  CONNECTED_CALLS
  SITE_VISITS
  MEETINGS          // legacy — kept for back-compat
  VIRTUAL_MEETINGS
  F2F_MEETINGS      // office + site combined (in-person)
  FRESH_CLIENTS     // new leads created (or cold→lead promotions)
  DEALS_CLOSED      // count of WON
  REVENUE_AED       // sum of won deals in AED
  REVENUE_INR
  BOOKINGS
}

model Target {
  id        String       @id @default(cuid())
  userId    String?
  team      String?
  metric    TargetMetric
  value     Float
  period    String       @default("DAILY")
  startDate DateTime     @default(now())
  endDate   DateTime?
  @@index([userId, metric, period])
  @@index([team, metric, period])
}

// =====================================================
// AGENT ATTENDANCE — login/logout tracking
// =====================================================

model AttendanceLog {
  id        String   @id @default(cuid())
  userId    String
  loginAt   DateTime @default(now())
  logoutAt  DateTime?
  ip        String?
  userAgent String?
  @@index([userId, loginAt])
}

// Daily attendance — drives round-robin (only PRESENT/LATE agents get leads).
// One row per agent per day. Auto-set on first login (PRESENT if before 10:30am,
// LATE after), can be admin-overridden.
enum AttendanceStatus {
  PRESENT     // logged in by 10:30am
  LATE        // logged in 10:30am-7pm
  ABSENT      // never logged in (or admin marked)
  ON_LEAVE    // admin marked — planned leave
}

model Attendance {
  id        String           @id @default(cuid())
  userId    String
  date      DateTime         @db.Date
  status    AttendanceStatus @default(PRESENT)
  markedAt  DateTime         @default(now())
  markedBy  String?          // null = self-mark / auto, else admin userId
  notes     String?
  @@unique([userId, date])
  @@index([date])
}
