{
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/morning-reminder",
      "schedule": "30 4 * * *"
    },
    {
      "path": "/api/cron/evening-reminder",
      "schedule": "30 12 * * *"
    }
  ]
}
