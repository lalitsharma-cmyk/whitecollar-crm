# ─────────────────────────────────────────────────────────────────────────────
# SANDBOX ENVIRONMENT — copy to the Vercel *sandbox* project's env vars.
#
# GOLDEN RULE: no production secret is ever reused here. Every value below is
# either sandbox-only, a throwaway, or intentionally blank so the feature is
# inert (no real emails, no real AI spend, no real telephony, no prod DB).
# ─────────────────────────────────────────────────────────────────────────────

# --- Database: the DEDICATED sandbox Neon DB (name/branch MUST contain
#     "sandbox"/"dev"/"test"/"staging"/"demo" — the seed guard enforces this). ---
DATABASE_URL="postgres://USER:PASS@ep-XXXX-sandbox.REGION.aws.neon.tech/wcr_sandbox?sslmode=require"

# The seed script reads this SEPARATE var (never DATABASE_URL) so it can be run
# from any shell without risk. Set it to the SAME sandbox URL as above.
SANDBOX_DATABASE_URL="postgres://USER:PASS@ep-XXXX-sandbox.REGION.aws.neon.tech/wcr_sandbox?sslmode=require"

# --- Marks the whole deploy as sandbox → shows the amber "SANDBOX" banner. ---
NEXT_PUBLIC_SANDBOX="1"

# --- Auth: sandbox-only secrets (generate fresh, do NOT copy prod). ---
NEXTAUTH_SECRET="GENERATE_A_FRESH_RANDOM_STRING_FOR_SANDBOX"
NEXTAUTH_URL="https://<your-sandbox-domain>"

# --- Cron: a DIFFERENT secret from prod, so sandbox cron calls can't hit prod
#     and vice-versa. (Sandbox crons only ever hit the sandbox deploy.) ---
CRON_SECRET="GENERATE_A_FRESH_RANDOM_STRING_FOR_SANDBOX"

# --- Intake webhook secret: fresh (public forms should NOT post real leads
#     here; use it only for test intake). ---
INTAKE_SECRET="GENERATE_A_FRESH_RANDOM_STRING_FOR_SANDBOX"

# --- Email (Resend): LEAVE BLANK so the sandbox sends NO real email.
#     Code paths that email will no-op / log instead of delivering. ---
RESEND_API_KEY=""
RESEND_FROM="sandbox@example.com"

# --- AI (Anthropic): leave BLANK to keep AI dormant (it already defaults OFF).
#     If interns need live AI, use a SEPARATE, budgeted test key — never prod's. ---
ANTHROPIC_API_KEY=""

# --- Web Push (VAPID): generate a FRESH keypair for sandbox (npx web-push
#     generate-vapid-keys). Do not reuse prod's, or prod devices get sandbox pushes. ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:sandbox@example.com"

# --- WhatsApp / telephony: leave BLANK. AS Phone stays inert; sandbox
#     recordings are dummy metadata only, never a real provider. ---
WHATSAPP_VERIFY_TOKEN=""

# --- Deploy hook: the sandbox Vercel project's OWN deploy hook (NOT prod's). ---
# VERCEL_DEPLOY_HOOK_URL="https://api.vercel.com/v1/integrations/deploy/SANDBOX_HOOK"
