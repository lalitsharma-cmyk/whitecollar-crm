# ─────────────────────────────────────────────────────────
# White Collar CRM — environment template
# Copy to `.env` (local dev) or set in Vercel (production)
# ─────────────────────────────────────────────────────────

# LOCAL DEV (SQLite, file-based)
DATABASE_URL="file:./dev.db"

# PRODUCTION (Postgres — Neon / Supabase / Railway)
# Comment out the SQLite line above and use:
# DATABASE_URL="postgresql://USER:PASS@HOST:5432/DB?sslmode=require"
#
# ⚡ For Neon + serverless (Vercel), use the POOLED endpoint and pgbouncer mode.
# This stops "too many connections" errors when many Vercel functions run at once.
# Pooled host has `-pooler` added before the region segment:
#   …ep-XXX-pooler.c-2.ap-southeast-1.aws.neon.tech…
# And add these query params: ?sslmode=require&pgbouncer=true&connection_limit=1
# Example:
# DATABASE_URL="postgresql://user:pass@ep-XXX-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgresql://user:pass@ep-XXX.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"  # only needed for migrations

# Public URL of this CRM (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"
# Production: "https://crm.whitecollarrealty.com"

# Session signing secret. GENERATE A NEW ONE FOR PRODUCTION:
#   openssl rand -base64 32
NEXTAUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"

# ─────────────────────────────────────────────────────────
# AI provider — set EITHER GEMINI_API_KEY (free) OR ANTHROPIC_API_KEY (paid).
# If both are set, Gemini wins (free → preferred default). If neither is set
# every AI feature falls back to rule-based so the CRM still works.
#
# Used for:
#   • Lead "Client Summary" + "Next Best Action" auto-refresh on every call
#   • Per-lead AI scoring (HOT / WARM / COLD)
#   • Ask-the-CRM chat
# ─────────────────────────────────────────────────────────

# GEMINI (FREE) — https://aistudio.google.com → Get API Key → paste below.
# Free tier: 15 req/min, 1500 req/day per project. Way more than enough for a
# sales team scoring 45-500 leads.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash-exp"

# ANTHROPIC (paid) — only set if you want Claude instead of Gemini.
# ~₹2-4 per analysis on claude-haiku-4-5. Skip if GEMINI_API_KEY is set.
ANTHROPIC_API_KEY=""
AI_MODEL="claude-haiku-4-5"

# WhatsApp Cloud API (Meta) webhook verify token. Anything secret you choose.
WHATSAPP_VERIFY_TOKEN="wcr-prod-verify-change-me"

# Intake HMAC secret (reserved for future signed embeds)
INTAKE_SECRET="change-me"

# ─────────────────────────────────────────────────────────
# FREE Web Push (browser notifications)
# Generate once with:  npx web-push generate-vapid-keys
# Then paste both keys here, AND in Vercel env vars (Project → Settings → Environment Variables)
# Also expose the PUBLIC key to the browser by setting NEXT_PUBLIC_VAPID_PUBLIC_KEY = VAPID_PUBLIC_KEY
# ─────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:lalit@whitecollarrealty.com"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# ─────────────────────────────────────────────────────────
# FREE Email via Resend (100/day, 3000/month forever)
# Sign up at https://resend.com → API Keys → Create
# Optional: verify crm.whitecollarrealty.com so mails come from your domain
# ─────────────────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM="WCR CRM <noreply@crm.whitecollarrealty.com>"

# ─────────────────────────────────────────────────────────
# Acefone cloud telephony (click-to-call + auto call logging)
# Sign up at https://acefone.com → API Tokens → generate
# In Acefone dashboard → Webhooks, point ALL triggers to:
#   https://crm.whitecollarrealty.com/api/acefone/webhook?token=<ACEFONE_WEBHOOK_TOKEN>
# Per-agent setup: open /team in CRM and paste each agent's Acefone agent id.
# ─────────────────────────────────────────────────────────
ACEFONE_API_KEY=""
ACEFONE_DID_NUMBER=""          # e.g. +911234567890 (India) or +971501234567 (UAE)
ACEFONE_WEBHOOK_TOKEN=""       # any random 32+ char string — used to verify webhooks
ACEFONE_BASE_URL=""            # optional; defaults to https://api.acefone.in (UK: https://api.acefone.co.uk)
ACEFONE_AUTO_CREATE_INBOUND="" # "true" to auto-create a lead from any unknown inbound caller

# ─────────────────────────────────────────────────────────
# Vercel Deploy Hook (manual deploy trigger)
# Bypasses the GitHub webhook entirely — used because Vercel's spam protection
# silently blocked deploys when the commit author email didn't match a GitHub
# account, and the webhook also stopped firing reliably.
#
# How to generate:
#   Vercel → Project → Settings → Git → Deploy Hooks → Create
#   Branch: main, Name: "manual-deploy"  →  copy URL
#
# How to use (after pasting the URL into .env):
#   npm run deploy   — triggers a fresh build of current main HEAD
#   npm run push     — git push + deploy in one shot
#
# ⚠️  SECRET — anyone with this URL can trigger production deploys.
# NEVER commit. .env is gitignored; this template stays empty.
# ─────────────────────────────────────────────────────────
VERCEL_DEPLOY_HOOK_URL=""

# ─────────────────────────────────────────────────────────
# Cron auth shared secret
# Used by /api/cron/* endpoints to reject the open internet.
# MUST be set identically in THREE places:
#   1. Vercel → Project → Settings → Environment Variables (Production)
#   2. GitHub repo → Settings → Secrets and variables → Actions
#   3. Here in local .env (so dev curls work)
# Generate with:  openssl rand -hex 32
# Why GitHub Actions: Vercel Hobby caps at 2 daily crons. We have 5 cron
# endpoints. The other 3 run via .github/workflows/cron.yml hitting these
# URLs with this secret as Bearer auth.
# ─────────────────────────────────────────────────────────
CRON_SECRET=""
