# ─────────────────────────────────────────────────────────
# White Collar CRM — environment template
# Copy to `.env` (local dev) or set in Vercel (production)
# ─────────────────────────────────────────────────────────

# LOCAL DEV (SQLite, file-based)
DATABASE_URL="file:./dev.db"

# PRODUCTION (Postgres — Neon / Supabase / Railway)
# Comment out the SQLite line above and use:
# DATABASE_URL="postgresql://USER:PASS@HOST:5432/DB?sslmode=require"

# Public URL of this CRM (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"
# Production: "https://crm.whitecollarrealty.com"

# Session signing secret. GENERATE A NEW ONE FOR PRODUCTION:
#   openssl rand -base64 32
NEXTAUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"

# AI provider — Anthropic (Claude). Optional; AI falls back to rule-based without it.
ANTHROPIC_API_KEY=""
AI_MODEL="claude-haiku-4-5"

# WhatsApp Cloud API (Meta) webhook verify token. Anything secret you choose.
WHATSAPP_VERIFY_TOKEN="wcr-prod-verify-change-me"

# Intake HMAC secret (reserved for future signed embeds)
INTAKE_SECRET="change-me"

# ─────────────────────────────────────────────────────────
# FREE Web Push (browser notifications)
# Generate once with:  npx web-push generate-vapid-keys
# Then paste both keys here, AND in Vercel env vars (Project → Settings → Environment Variables)
# Also expose the PUBLIC key to the browser by setting NEXT_PUBLIC_VAPID_PUBLIC_KEY = VAPID_PUBLIC_KEY
# ─────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:lalit@whitecollarrealty.com"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# ─────────────────────────────────────────────────────────
# FREE Email via Resend (100/day, 3000/month forever)
# Sign up at https://resend.com → API Keys → Create
# Optional: verify crm.whitecollarrealty.com so mails come from your domain
# ─────────────────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM="WCR CRM <noreply@crm.whitecollarrealty.com>"
